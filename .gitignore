# ChaosCypher Monorepo .gitignore
# This monorepo tracks all packages, scripts, tests, and tooling.
# Documentation source lives in packages/docs/ (Docusaurus).

# ============================================================================
# SUPERPOWERS (brainstorm mockups, ephemeral)
# ============================================================================
.superpowers/

# ============================================================================
# PLAYWRIGHT MCP (local session logs, ephemeral)
# ============================================================================
.playwright-mcp/

# ============================================================================
# CLAUDE CODE / MCP (local config, not tracked)
# ============================================================================
.claude/
.mcp.json

# ============================================================================
# LOCAL SCRATCH (screenshots, ad-hoc captures, agent exploration notes)
# ============================================================================
.scratch/

# ============================================================================
# BUILD ARTIFACTS
# ============================================================================
/dist/
/build/
/.cache/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
.eggs/

# ============================================================================
# UV (workspace virtualenv and per-project caches; uv.lock IS committed)
# ============================================================================
.venv/
.uv-cache/

# ============================================================================
# LOCAL CONFIGURATION (never commit)
# ============================================================================
# Match any .env* file anywhere in the tree (e.g. packages/cortex/.env), with
# an explicit allow-list carve-out for tracked .env.example templates.
**/.env
**/.env.*
!**/.env.example
/.secrets/
.vscode/
.idea/

# ============================================================================
# LOGS (local only)
# ============================================================================
/logs/
*.log

# ============================================================================
# LOCAL DATABASES (fixtures must be explicitly allow-listed)
# ============================================================================
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal
!e2e/fixtures/snapshots/*.db
!e2e/fixtures/snapshots/*.sqlite
!e2e/fixtures/snapshots/*.sqlite3

# ============================================================================
# OS FILES
# ============================================================================
.DS_Store
Thumbs.db
desktop.ini
nul

# ============================================================================
# TESTING ARTIFACTS
# ============================================================================
.pytest_cache/
.coverage
.coverage.*
coverage.xml
diff-cover.md
coverage_html/
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
test-reports/

# Mutation testing scratch trees (mutmut copies the package into
# packages/core/mutants/ and instruments every source file; Stryker
# writes its HTML/JSON reports under packages/interface/reports/). Both
# are regenerated by `make mutate` -- never commit them.
mutants/
packages/interface/reports/
packages/interface/.stryker-tmp/

# Build/test output files
*_output.txt
mypy_output.txt
mypy_full_output.txt

# ============================================================================
# NODE.JS
# ============================================================================
node_modules/

# ============================================================================
# TEST DATA FILES
# ============================================================================
tests/*.txt
tests/*.pdf

# ============================================================================
# GIT WORKTREES
# ============================================================================
.worktrees/

# ============================================================================
# GENERATED OPENAPI ARTIFACTS (CI regenerates; never commit)
# ============================================================================
/build/openapi.json
/build/_openapi_tmp/
/packages/interface/src/types/generated/

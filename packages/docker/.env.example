# Project name (overrides directory name)
# This will show as "chaoscypher" in Docker Desktop
COMPOSE_PROJECT_NAME=chaoscypher

# Bind address. Default 0.0.0.0 — accessible from your LAN (matches the
# self-hosted convention: Vaultwarden / Jellyfin / Home Assistant / Gitea).
# The first user to reach /setup becomes the admin (first-arrival race);
# see docs/security/self-hosted-threat-model.md for the trade-off and the
# recommended hardening when exposing the box beyond your local machine.
# Set to 127.0.0.1 if you only want access from this machine.
# CHAOSCYPHER_BIND=127.0.0.1

# Host header allow-list for LAN/proxy deployments. Keep localhost-only unless
# you intentionally expose the app on a LAN hostname/IP.
# CHAOSCYPHER_ALLOWED_HOSTS=localhost,127.0.0.1,::1,my-host.local,192.168.1.20

# Edge auth tokens are auto-generated into deployment-local Docker volumes.
# Operators normally should not set CHAOSCYPHER_EDGE_AUTH_TOKEN. See README.md
# for token locations and rotation steps.

# ============================================================================
# Orchestration tunables (PR1: eliminate hardcoded values)
# ============================================================================
# These env vars override Pydantic settings.yaml values for the orchestration
# layer (compose grace periods, valkey memory). For most settings, prefer
# editing settings.yaml directly. These env-driven knobs exist where compose
# itself needs the value (e.g. stop_grace_period is set BY compose, not by
# the rendered configs).

# Container shutdown grace period (default 60s, must be >= ShutdownSettings.
# cortex_shutdown_grace_seconds AND worker_shutdown_grace_seconds)
# CHAOSCYPHER_STOP_GRACE_PERIOD=60s

# Worker-specific stop grace period (multi-container only).
# Default is 30s, matching ShutdownSettings.worker_shutdown_grace_seconds.
# (Was 60s in the legacy hardcoded compose. Operators with long-running
# task drain needs should set CHAOSCYPHER_WORKER_STOP_GRACE_PERIOD=60s.)
# CHAOSCYPHER_WORKER_STOP_GRACE_PERIOD=30s

# Valkey memory limit (matches QueueSettings.max_memory; default 2gb)
# Renamed from QUEUE_MAX_MEMORY for naming consistency with the Pydantic
# settings field.
# CHAOSCYPHER_VALKEY_MAXMEMORY=2gb

# ============================================================================
# Healthcheck timings — multi-container only
# ============================================================================
# Consumed by packages/docker/multi-container/docker-compose.{dev,prod}.yml
# (the compose-level `healthcheck:` blocks) and by the per-service
# healthcheck scripts (config/healthcheck.py, multi-container/{cortex,
# neuron}/healthcheck.py).
#
# The all-in-one stack (packages/docker/docker-compose.yml) does not declare
# a compose-level healthcheck; its image-level HEALTHCHECK is baked into the
# Dockerfile at build time and is unaffected by these overrides.
# CHAOSCYPHER_HEALTH_INTERVAL=30s
# CHAOSCYPHER_HEALTH_TIMEOUT=10s
# CHAOSCYPHER_HEALTH_START_PERIOD=60s
# CHAOSCYPHER_HEALTH_RETRIES=3
# CHAOSCYPHER_VALKEY_HEALTH_INTERVAL=10s
# CHAOSCYPHER_VALKEY_HEALTH_TIMEOUT=3s
# CHAOSCYPHER_VALKEY_HEALTH_START=10s

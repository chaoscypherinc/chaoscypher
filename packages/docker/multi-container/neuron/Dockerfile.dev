# Chaos Cypher Neuron - Development with hot-reload
FROM python:3.14.3-slim

WORKDIR /app

# Install system dependencies for media processing (OCR + audio extraction)
RUN apt-get update && \
    apt-get install -y --no-install-recommends tesseract-ocr tesseract-ocr-eng ffmpeg && \
    rm -rf /var/lib/apt/lists/*

# Step 1: Copy ONLY dependency manifests (rarely change → cached layer)
COPY packages/core/pyproject.toml /app/packages/core/pyproject.toml
COPY packages/neuron/pyproject.toml /app/packages/neuron/pyproject.toml

# Step 2: Create minimal package structure for editable install
RUN mkdir -p /app/packages/core/src/chaoscypher_core && \
    mkdir -p /app/packages/neuron/src/chaoscypher_neuron && \
    touch /app/packages/core/src/chaoscypher_core/__init__.py && \
    touch /app/packages/neuron/src/chaoscypher_neuron/__init__.py

# Step 3: Install PyTorch CPU-only first (avoids ~4GB of unused NVIDIA CUDA libs)
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install torch==2.10.0 --index-url https://download.pytorch.org/whl/cpu

# Step 4: Install remaining dependencies + watchdog (cached until pyproject.toml changes)
# Neuron depends on Core only (no Cortex, no Runtime — see CLAUDE.md).
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install watchdog && \
    pip install -e /app/packages/core && \
    pip install -e /app/packages/neuron

# Step 5: Copy actual source code (overridden by volume mounts in dev)
COPY packages/core/src /app/packages/core/src
COPY packages/neuron/src /app/packages/neuron/src

# Copy healthcheck script
COPY packages/docker/multi-container/neuron/healthcheck.py /healthcheck.py

# Copy shared entrypoint script (strip CRLF for Windows git checkout compatibility)
COPY packages/docker/config/entrypoint.sh /entrypoint.sh
RUN sed -i 's/\r$//' /entrypoint.sh && chmod +x /entrypoint.sh

# Create non-root user and data directory with correct ownership.
# Docker named volumes initialize from the container filesystem on first use,
# so /data will be owned by appuser when the volume is created.
RUN groupadd -g 1000 appuser && \
    useradd -u 1000 -g appuser -s /bin/bash -m appuser && \
    mkdir -p /data && \
    chown appuser:appuser /data

# Environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app

USER appuser

ENTRYPOINT ["/entrypoint.sh"]

# Default: Start unified worker with hot-reload (can be overridden)
CMD ["watchmedo", "auto-restart", \
     "-d", "/app/packages/core/src", \
     "-d", "/app/packages/neuron/src", \
     "-p", "*.py", \
     "--interval=2.0", \
     "--debounce-interval=1.0", \
     "--ignore-patterns=*/__pycache__/*;*.pyc", \
     "--", \
     "cc-neuron"]

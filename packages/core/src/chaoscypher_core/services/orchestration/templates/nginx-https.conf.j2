{%- set bs = settings.batching -%}
{%- set upload_bytes = bs.max_upload_bytes -%}
{%- if upload_bytes >= 1073741824 -%}
{%- set upload_size_str = (upload_bytes // 1073741824) | string ~ "g" -%}
{%- elif upload_bytes >= 1048576 -%}
{%- set upload_size_str = (upload_bytes // 1048576) | string ~ "m" -%}
{%- else -%}
{%- set upload_size_str = (upload_bytes // 1024) | string ~ "k" -%}
{%- endif -%}
# Chaos Cypher All-in-One — HTTPS mode (nginx auth_request model)
# TLS termination + redirect HTTP to HTTPS
#
# Every /api/ request is gated by an internal subrequest to
# /auth/verify — unless it's a public auth endpoint (/status /setup /login
# /logout) needed to bootstrap or recover auth state. The verify endpoint
# sets X-Auth-User on success; this header is forwarded to Cortex, which
# reads it via the CurrentUsername dependency.

log_format json_access escape=json
    '{"timestamp":"$time_iso8601",'
    '"level":"info",'
    '"event":"http_request",'
    '"source":"nginx",'
    '"method":"$request_method",'
    '"path":"$uri",'
    '"status":$status,'
    '"bytes":$body_bytes_sent,'
    '"duration_ms":$request_time,'
    '"remote_addr":"$remote_addr",'
    '"user_agent":"$http_user_agent"}';

access_log /dev/stdout json_access;

{% if settings.rate_limit.enabled %}
# Rate limiting zones
limit_req_zone $binary_remote_addr zone=auth:10m rate={{ settings.rate_limit.login_max_requests }}r/s;
limit_req_zone $binary_remote_addr zone=api_general:10m rate={{ settings.rate_limit.api_general_max_requests }}r/s;
limit_req_zone $binary_remote_addr zone=uploads:10m rate={{ settings.rate_limit.uploads_max_requests }}r/s;

# Mutations zone — applies only to POST/PUT/PATCH/DELETE via the per-method
# key map below. GET/HEAD/OPTIONS resolve to an empty key and bypass the limit
# (nginx skips limit_req evaluation when the key is empty). Closes the
# network-retry double-submit risk on upload, chat send, queue POST, etc.
# without requiring an Idempotency-Key API contract.
map $request_method $chaoscypher_mutation_key {
    default      "";
    POST         $binary_remote_addr;
    PUT          $binary_remote_addr;
    PATCH        $binary_remote_addr;
    DELETE       $binary_remote_addr;
}
limit_req_zone $chaoscypher_mutation_key zone=mutations:10m rate={{ settings.rate_limit.mutations_max_requests }}r/s;
{% endif %}

# HTTP to HTTPS redirect
server {
    listen 80;
    server_name _;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    return 301 https://$host$request_uri;
}

# HTTPS server
server {
    listen 443 ssl;
    server_name _;

    include /run/chaoscypher/edge-auth-token-var.conf;

    ssl_certificate {{ settings.tls.cert_dir }}/{{ settings.tls.cert_filename }};
    ssl_certificate_key {{ settings.tls.cert_dir }}/{{ settings.tls.key_filename }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_dhparam /etc/nginx/dhparam.pem;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    # Security headers
    include /etc/nginx/security-headers.conf;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Branded error pages
    error_page 502 503 /startup.html;
    error_page 400 403 404 408 413 500 504 /error.html;
    location = /startup.html {
        root /usr/share/nginx/html;
        internal;
        add_header Content-Security-Policy "default-src 'self'; script-src 'unsafe-inline'; style-src 'unsafe-inline'; img-src 'self' data:; connect-src 'self';" always;
        # Never cache the splash — its whole job is to disappear once the
        # service it covers comes back up.
        add_header Cache-Control "no-store" always;
        include /etc/nginx/security-headers-no-csp.conf;
    }
    location = /error.html {
        root /usr/share/nginx/html;
        internal;
        add_header Content-Security-Policy "default-src 'self'; script-src 'unsafe-inline'; style-src 'unsafe-inline'; img-src 'self' data:; connect-src 'self';" always;
        include /etc/nginx/security-headers-no-csp.conf;
    }
    location = /startup-logo.png {
        alias /usr/share/nginx/html/logo.png;
    }

    # Request limits — 1m default; upload size only on source-upload routes below.
    client_max_body_size 1m;
    # Buffer bodies up to 256k in memory; only spill to /var/lib/nginx/body/
    # for genuine uploads. Default (8k/16k) was tripping the "request body is
    # buffered to a temporary file" warning on routine JSON PATCH/POSTs.
    client_body_buffer_size 256k;

    gzip on;
    gzip_vary on;
    gzip_min_length 1000;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml text/javascript;

    # ========================================================================
    # Auth
    # ========================================================================

    # Internal auth check — nginx subrequest only.
    location = /auth/verify {
        internal;
        # auth_request subrequests inherit server-level client_max_body_size and
        # apply this location's limit too — the smaller wins. Without this line
        # an upload larger than the server default (1m) trips 413 in the auth
        # subrequest before the upload location's override kicks in.
        client_max_body_size {{ upload_size_str }};
        proxy_pass http://127.0.0.1:8080/api/v1/auth/verify;
        proxy_pass_request_body off;
        proxy_set_header Content-Length "";
        proxy_set_header X-Original-URI $request_uri;
        proxy_set_header Host $host;
        proxy_set_header Cookie $http_cookie;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header X-Auth-User "";
        proxy_set_header X-Auth-Edge-Token "";
    }

    # Public auth endpoints (bootstrap + recovery). Not behind auth_request.
    location = /api/v1/auth/status {
        proxy_pass http://127.0.0.1:8080;
        include /etc/nginx/proxy-public.conf;
    }
    location = /api/v1/auth/setup {
{% if settings.rate_limit.enabled %}
        limit_req zone=auth burst=3 nodelay;
{% endif %}
        proxy_pass http://127.0.0.1:8080;
        include /etc/nginx/proxy-public.conf;
    }
    location = /api/v1/auth/login {
{% if settings.rate_limit.enabled %}
        limit_req zone=auth burst=3 nodelay;
{% endif %}
        proxy_pass http://127.0.0.1:8080;
        include /etc/nginx/proxy-public.conf;
    }
    location = /api/v1/auth/logout {
        proxy_pass http://127.0.0.1:8080;
        include /etc/nginx/proxy-public.conf;
    }

    # Public settings endpoint — auth-exempt so the SPA can read operator-tunable
    # config (page sizes, polling intervals, validation limits) before login to
    # render the login screen with the correct defaults. Never includes secrets.
    location = /api/v1/settings/public {
        proxy_pass http://127.0.0.1:8080;
        include /etc/nginx/proxy-public.conf;
    }

    # Access hint — auth-exempt. The setup wizard's Account step calls this
    # before authentication is set up, to decide whether to pre-check the
    # "Allow access from other devices" toggle for users arriving over LAN.
    location = /api/v1/settings/host {
        proxy_pass http://127.0.0.1:8080;
        include /etc/nginx/proxy-public.conf;
    }

    # Container healthcheck endpoint — soft-auth: must be reachable
    # without a session so Docker's HEALTHCHECK keeps working pre-login,
    # but if the caller IS authenticated we forward identity so the
    # cortex handler returns the full `checks` payload (used by the
    # MiniSystemStatus dropdown). Anonymous callers (Docker HEALTHCHECK,
    # LAN scanners) fall through to @health_unauth which strips auth
    # headers and yields only {healthy, status}.
    location = /api/v1/health {
        auth_request /auth/verify;
        auth_request_set $health_auth_user $upstream_http_x_auth_user;
        error_page 401 403 = @health_unauth;

        include /etc/nginx/proxy-common.conf;
        proxy_set_header X-Auth-User $health_auth_user;
        proxy_set_header X-Auth-Edge-Token $chaoscypher_edge_auth_token;
        proxy_pass http://127.0.0.1:8080;
    }
    location @health_unauth {
        internal;
        proxy_pass http://127.0.0.1:8080;
        include /etc/nginx/proxy-public.conf;
    }

    # ========================================================================
    # Protected API
    # ========================================================================

    # Upload endpoints — auth + stricter rate limit.
    location ~ ^/api/v1/sources(/batch|/url)?$ {
        client_max_body_size {{ upload_size_str }};
{% if settings.rate_limit.enabled %}
        limit_req zone=uploads burst=5 nodelay;
{% endif %}
        proxy_pass http://127.0.0.1:8080;
        include /etc/nginx/edge-auth-proxy.conf;
    }

    # All remaining /api/ traffic: auth-gated general rate limit + per-method
    # mutations cap. nginx evaluates multiple `limit_req` directives in a
    # location; the first one to trip throttles the request. The mutations
    # zone keys on method (POST/PUT/PATCH/DELETE) so reads are unaffected.
    location /api/ {
{% if settings.rate_limit.enabled %}
        limit_req zone=api_general burst=50 nodelay;
        limit_req zone=mutations burst={{ settings.rate_limit.mutations_burst }} nodelay;
{% endif %}
        proxy_pass http://127.0.0.1:8080;
        include /etc/nginx/edge-auth-proxy.conf;
    }

    include /etc/nginx/edge-unauthorized.conf;

    # ========================================================================
    # SPA + static assets
    # ========================================================================

    location /assets/ {
        proxy_pass http://127.0.0.1:8080;
        include /etc/nginx/proxy-public.conf;
    }

    location / {
{% if settings.rate_limit.enabled %}
        limit_req zone=api_general burst=50 nodelay;
{% endif %}
        proxy_pass http://127.0.0.1:8080;
        include /etc/nginx/proxy-public.conf;
    }
}

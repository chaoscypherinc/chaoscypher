{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:medical",
  "name": "medical",
  "version": "1.10.0",
  "description": "Medical and clinical documents, healthcare literature, and pharmaceutical information",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.2,
  "strict_entity_types": true,
  "entity_exclusions": [
    {
      "description": "Dosage numbers alone",
      "examples": [
        "500mg",
        "2x daily",
        "10ml"
      ]
    },
    {
      "description": "Generic measurements",
      "examples": [
        "normal range",
        "elevated levels",
        "within limits"
      ]
    },
    {
      "description": "Study references",
      "examples": [
        "Figure 1",
        "Table 2",
        "Reference [15]"
      ]
    },
    {
      "description": "Editorial commentary",
      "examples": [
        "it is worth noting",
        "importantly"
      ]
    }
  ],
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "clinical_core": {
        "terms": [
          "diagnosis",
          "treatment",
          "symptoms",
          "patient",
          "clinical",
          "prognosis",
          "medical",
          "healthcare",
          "disease",
          "disorder",
          "syndrome"
        ],
        "weight": 1.2
      },
      "pharmaceutical": {
        "terms": [
          "dosage",
          "mg",
          "prescribed",
          "contraindicated",
          "adverse effect",
          "drug",
          "medication",
          "pharmaceutical",
          "FDA",
          "indication",
          "formulation"
        ],
        "weight": 1.0
      },
      "diagnostic": {
        "terms": [
          "test",
          "imaging",
          "biopsy",
          "MRI",
          "CT scan",
          "blood test",
          "screening",
          "examination",
          "differential diagnosis",
          "laboratory"
        ],
        "weight": 0.9
      },
      "anatomy": {
        "terms": [
          "cardiac",
          "pulmonary",
          "hepatic",
          "renal",
          "neurological",
          "gastrointestinal",
          "musculoskeletal",
          "endocrine",
          "cardiovascular"
        ],
        "weight": 0.8
      },
      "procedures": {
        "terms": [
          "surgery",
          "procedure",
          "intervention",
          "therapy",
          "operation",
          "transplant",
          "catheterization",
          "endoscopy"
        ],
        "weight": 0.9
      },
      "clinical_terms": {
        "terms": [
          "etiology",
          "pathology",
          "pathogenesis",
          "epidemiology",
          "morbidity",
          "mortality",
          "incidence",
          "prevalence",
          "comorbidity"
        ],
        "weight": 0.8
      }
    },
    "file_extensions": [
      ".pdf"
    ],
    "doc_types": [
      "medical_document",
      "clinical_record",
      "pharmaceutical"
    ],
    "patterns": [
      {
        "regex": "(?i)\\b\\d+\\s*(mg|mcg|ml|iu|kg|mmol|units?)\\b",
        "weight": 1.4,
        "description": "Dosage notation"
      },
      {
        "regex": "(?i)\\bICD-?(10|11)?[-:]?[A-Z]\\d+",
        "weight": 1.5,
        "description": "ICD code pattern"
      },
      {
        "regex": "(?i)\\b(q\\.?d\\.?|b\\.?i\\.?d\\.?|t\\.?i\\.?d\\.?|q\\.?i\\.?d\\.?|p\\.?r\\.?n\\.?|p\\.?o\\.?|i\\.?v\\.?|i\\.?m\\.?)\\b",
        "weight": 1.3,
        "description": "Prescription abbreviations"
      },
      {
        "regex": "(?i)\\b(stage|grade|class|type)\\s+[IVXivx\\d]+[a-d]?\\b",
        "weight": 1.2,
        "description": "Disease staging/classification"
      },
      {
        "regex": "(?i)\\b(diagnosis|dx|treatment|tx|prognosis|history|hx)\\b",
        "weight": 1.0,
        "description": "Clinical abbreviations"
      }
    ],
    "confidence": {
      "base_score": 0.25,
      "per_keyword_boost": 0.04,
      "extension_boost": 0.1,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- Extract conditions, symptoms, treatments, drugs, procedures, and anatomical locations\n- Include dosage information as properties on drug entities\n- Use standardized medical terminology when possible\n\nDO NOT EXTRACT:\n- Dosage numbers alone: '500mg', '2x daily' (attach to drug entity as property)\n- Generic measurements: 'normal range', 'elevated levels' (without specific values)\n- Study references: Figure 1, Table 2, Reference [15]\n- Administrative codes: ICD-10 codes, CPT codes (unless discussing the code itself)",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- CAUSATION: Link conditions to causes with causes relationship\n- TREATMENT: Connect drugs/procedures to conditions with treats\n- INTERACTIONS: Capture drug interactions with interacts_with, contraindicated_with\n- ANATOMY: Link conditions/symptoms to anatomical locations with affects\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",
  "templates": {
    "node_templates": [
      {
        "@type": "NodeTemplate",
        "id": "med_template_condition",
        "name": "Condition",
        "description": "A disease, disorder, syndrome, or medical condition",
        "icon": "Coronavirus",
        "color": "#7041d6",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "clinical",
        "normalization_keywords": [
          "a disease",
          "disorder",
          "condition",
          "syndrome",
          "illness",
          "diagnosed with",
          "suffers from",
          "presents with"
        ],
        "properties": [
          {
            "name": "severity",
            "display_name": "Severity",
            "property_type": "text",
            "absorbs_types": [
              "Severity"
            ]
          },
          {
            "name": "stage",
            "display_name": "Stage",
            "property_type": "text",
            "absorbs_types": [
              "Stage"
            ]
          }
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "med_template_symptom",
        "name": "Symptom",
        "description": "A clinical symptom, sign, or manifestation",
        "icon": "MonitorHeart",
        "color": "#a541d6",
        "requires_named_referent": false,
        "quality_score": 18,
        "compatibility_group": "clinical",
        "normalization_keywords": [
          "symptom",
          "presents with",
          "clinical sign",
          "manifestation",
          "complains of",
          "experiences"

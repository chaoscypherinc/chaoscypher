{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:biographical",
  "name": "biographical",
  "version": "1.9.0",
  "description": "Biographies, memoirs, personal histories, and biographical documents",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.0,
  "strict_entity_types": true,
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "biographical_core": {
        "terms": [
          "biography",
          "memoir",
          "autobiography",
          "life story",
          "personal history",
          "born",
          "died",
          "childhood",
          "early life"
        ],
        "weight": 1.2
      },
      "life_events": {
        "terms": [
          "birth",
          "death",
          "marriage",
          "divorce",
          "graduation",
          "career",
          "retirement",
          "achievement",
          "award",
          "milestone"
        ],
        "weight": 1.0
      },
      "relationships": {
        "terms": [
          "father",
          "mother",
          "spouse",
          "child",
          "sibling",
          "family",
          "mentor",
          "colleague",
          "friend",
          "partner"
        ],
        "weight": 0.9
      },
      "education_career": {
        "terms": [
          "education",
          "school",
          "university",
          "degree",
          "profession",
          "occupation",
          "position",
          "title",
          "promoted",
          "appointed"
        ],
        "weight": 0.8
      },
      "legacy": {
        "terms": [
          "legacy",
          "contribution",
          "influence",
          "remembered for",
          "known for",
          "famous for",
          "notable",
          "pioneered"
        ],
        "weight": 0.8
      },
      "time_markers": {
        "terms": [
          "years old",
          "at age",
          "in his youth",
          "during her career",
          "later in life",
          "final years"
        ],
        "weight": 0.7
      }
    },
    "file_extensions": [],
    "doc_types": [
      "biography",
      "memoir",
      "obituary",
      "profile"
    ],
    "patterns": [
      {
        "regex": "(?i)\\b(born|died|b\\.|d\\.)\\s+(on\\s+)?[A-Z][a-z]+\\s+\\d{1,2},?\\s+\\d{4}\\b",
        "weight": 1.5,
        "description": "Birth/death dates"
      },
      {
        "regex": "\\(\\d{4}\\s*[-��]\\s*\\d{4}\\)",
        "weight": 1.4,
        "description": "Life span in parentheses"
      },
      {
        "regex": "(?i)\\b(at age|aged|at the age of)\\s+\\d+\\b",
        "weight": 1.2,
        "description": "Age references"
      },
      {
        "regex": "(?i)\\b(early life|childhood|education|career|personal life|legacy|death)\\b",
        "weight": 1.0,
        "description": "Biography section headers"
      }
    ],
    "confidence": {
      "base_score": 0.25,
      "per_keyword_boost": 0.04,
      "extension_boost": 0.0,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_exclusions": [
    {
      "description": "Bare date ranges without context",
      "examples": [
        "1920-1985",
        "1800s"
      ]
    },
    {
      "description": "Generic familial roles without names",
      "examples": [
        "the father",
        "a sister",
        "the wife"
      ]
    },
    {
      "description": "Source citations and footnote markers",
      "examples": [
        "[1]",
        "(ibid.)"
      ]
    },
    {
      "description": "Vague time references",
      "examples": [
        "in his youth",
        "later in life",
        "during this period"
      ]
    }
  ],
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- NAMES: Use canonical name. Put ALL variants in aliases (maiden names, pen names, titles, nicknames)\n- TIMELINE: Capture life events with dates in properties when mentioned\n- Extract people, organizations, locations, and significant events\n\nDO NOT EXTRACT:\n- Vague time references: 'in his youth', 'later in life', 'during this period'\n- Generic roles: 'a friend', 'a colleague' (without specific identity)\n- Source citations: [1], (ibid.), page numbers\n- Editorial commentary: 'it is said that', 'historians believe'",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- FAMILY: Use spouse_of, parent_of, child_of for family relationships\n- CAREER: Link achievements to institutions with worked_at, educated_at\n- Use influenced_by for mentorship and influence relationships\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",
  "templates": {
    "node_templates": [
      {
        "@type": "NodeTemplate",
        "id": "bio_template_person",
        "name": "Person",
        "description": "The biographical subject or related person",
        "icon": "Person",
        "color": "#89d641",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "people",
        "normalization_keywords": [
          "person",
          "individual",
          "he",
          "she",
          "subject",
          "figure"
        ],
        "properties": [
          {
            "name": "birth_date",
            "display_name": "Birth Date",
            "property_type": "date",
            "absorbs_types": [
              "Birth Date"
            ]
          },
          {
            "name": "death_date",
            "display_name": "Death Date",
            "property_type": "date",
            "absorbs_types": [
              "Death Date"
            ]
          },
          {
            "name": "birth_place",
            "display_name": "Birth Place",
            "property_type": "text",
            "absorbs_types": [
              "Birth Place"
            ]
          },
          {
            "name": "occupation",
            "display_name": "Occupation",
            "property_type": "text",
            "absorbs_types": [
              "Occupation"
            ]
          },
          {
            "name": "title",
            "display_name": "Title/Rank",
            "property_type": "text",
            "absorbs_types": [
              "Title"
            ]
          },
          {
            "name": "nationality",
            "display_name": "Nationality",
            "property_type": "text",
            "absorbs_types": [
              "Nationality"
            ]
          }
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "bio_template_event",
        "name": "Life Event",
        "description": "A significant life event (birth, marriage, career change)",
        "icon": "Event",
        "color": "#49d641",
        "requires_named_referent": false,
        "quality_score": 18,
        "compatibility_group": "events",
        "normalization_keywords": [
          "event",
          "occurred",
          "happened",
          "took place",
          "born",
          "died",
          "married"
        ],
        "properties": [
          {
            "name": "event_date",
            "display_name": "Date",
            "property_type": "date"
          },
          {
            "name": "event_location",
            "display_name": "Location",
            "property_type": "text"
          }
        ]
      },

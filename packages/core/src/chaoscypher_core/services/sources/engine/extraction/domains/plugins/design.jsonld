    "file_extensions": [
      ".pdf",
      ".epub"
    ],
    "doc_types": [
      "design_book",
      "design_system_doc",
      "style_guide",
      "ux_research",
      "accessibility_guideline",
      "brand_guideline"
    ],
    "patterns": [
      {
        "regex": "#[0-9A-Fa-f]{3}(?:[0-9A-Fa-f]{3})?(?:[0-9A-Fa-f]{2})?\\b",
        "weight": 1.4,
        "description": "Hex color codes (#FFF / #FFFFFF / #FFFFFFFF)"
      },
      {
        "regex": "(?i)\\bWCAG\\s*(?:2\\.\\d|AA|AAA|A)\\b",
        "weight": 1.5,
        "description": "WCAG conformance references"
      },
      {
        "regex": "\\b\\d+(?:\\.\\d+)?\\s*(?:px|rem|em|vh|vw|ch|ex|pt)\\b",
        "weight": 1.0,
        "description": "CSS length units (px/rem/em/vh/vw)"
      },
      {
        "regex": "\\b\\d+(?:\\.\\d+)?\\s*:\\s*1\\b",
        "weight": 1.2,
        "description": "Contrast ratio notation (e.g. 4.5:1)"
      },
      {
        "regex": "(?i)\\bfigma\\.com/(?:file|design|board|community)/",
        "weight": 1.6,
        "description": "Figma file/design URLs"
      },
      {
        "regex": "(?i)\\b(?:rgb|rgba|hsl|hsla)\\s*\\(",
        "weight": 1.2,
        "description": "CSS color function notation"
      },
      {
        "regex": "(?i)\\b(?:8|4)px\\s*(?:grid|baseline|spacing)\\b",
        "weight": 1.3,
        "description": "Baseline grid references (4px / 8px grid)"
      },
      {
        "regex": "(?i)\\b(?:Nielsen|Norman|Krug|Cooper|Wroblewski|Spool)['’]s?\\b",
        "weight": 1.4,
        "description": "Canonical UX thinker references"
      }
    ],
    "confidence": {
      "base_score": 0.25,
      "per_keyword_boost": 0.04,
      "extension_boost": 0.05,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- Extract named designers, named design systems (Material Design, HIG, Fluent), named tools (Figma, Sketch)\n- Extract reusable components by canonical name (Button, Modal, Card) — capture the variant or state as a property, not as a separate type\n- Extract design principles and heuristics as their own entities with a quoted statement when available\n- Extract typefaces by family name (Inter, Helvetica, Roboto); attach foundry and classification as properties\n- Extract color palettes by name; extract individual colors with their hex value as a property\n- Extract accessibility guidelines with WCAG level (A / AA / AAA) and success criterion when stated\n- Extract user research methods by name (card sorting, A/B test, usability test, heuristic evaluation)\n\nDO NOT EXTRACT:\n- Generic component references without a system or designer context: 'a button', 'the modal'\n- Bare CSS values without context: '16px', '#fff', '100%'\n- Figure / chapter cross-references: 'fig. 1', 'see chapter 3'\n- Sample copy / placeholder text: 'Lorem ipsum'",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- AUTHORSHIP: Use designed_by for designer-to-component, created_by for designer-to-system\n- SYSTEM MEMBERSHIP: Use part_of_system for component-to-design-system, defines for system-to-color-palette/typeface\n- INFLUENCE: Use inspired_by between design systems (often symmetric), influenced_by between designers\n- COMPLIANCE: Use complies_with for component-to-accessibility-guideline, follows_principle for component-to-principle\n- TOOL USE: Use uses_tool for designer-to-tool, supports for tool-to-system\n- EVALUATION: Use evaluated_by for component-to-research-method, violates_heuristic for issue-to-heuristic\n- COLOR: Use pairs_with for symmetric color-to-color relationships (complementary, analogous)\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",
  "templates": {
    "node_templates": [
      {
        "@type": "NodeTemplate",
        "id": "design_template_designer",
        "name": "Designer",
        "description": "A named designer, design author, or UX thinker (e.g., Don Norman, Dieter Rams, Jakob Nielsen)",
        "icon": "Brush",
        "color": "#d6418a",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "people",
        "normalization_keywords": [
          "designer",
          "UX designer",
          "UI designer",
          "product designer",
          "visual designer",
          "interaction designer",
          "design author",
          "design researcher"

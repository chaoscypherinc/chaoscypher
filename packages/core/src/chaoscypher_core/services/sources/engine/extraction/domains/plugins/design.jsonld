{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:design",
  "name": "design",
  "version": "1.10.0",
  "description": "UI/UX design books, design systems documentation, typography, color theory, accessibility guidelines, visual design principles, and interaction design references",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.2,
  "strict_entity_types": true,
  "type_aliases": {
    "UI Designer": "Designer",
    "UX Designer": "Designer",
    "Product Designer": "Designer",
    "Visual Designer": "Designer",
    "Interaction Designer": "Designer",
    "Button": "Component",
    "Modal": "Component",
    "Dialog": "Component",
    "Card": "Component",
    "Dropdown": "Component",
    "Font": "Typeface",
    "Palette": "Color Palette",
    "Wireframe": "Mockup",
    "Prototype": "Mockup",
    "A11y Guideline": "Accessibility Guideline",
    "WCAG Guideline": "Accessibility Guideline",
    "Studio": "Organization",
    "Design Studio": "Organization",
    "Agency": "Organization",
    "Design Agency": "Organization",
    "Company": "Organization"
  },
  "entity_exclusions": [
    {
      "description": "Generic design references without specifics",
      "examples": [
        "the button",
        "the user",
        "the designer",
        "the interface",
        "the screen"
      ]
    },
    {
      "description": "Figure and chapter markers",
      "examples": [
        "fig. 1",
        "figure 2",
        "see chapter 3",
        "as shown above"
      ]
    },
    {
      "description": "Standalone CSS values",
      "examples": [
        "16px",
        "1rem",
        "100%",
        "0 auto"
      ]
    }
  ],

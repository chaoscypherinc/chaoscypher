        "aliases": [
          "Nielsen's heuristics",
          "Nielsen heuristics",
          "the ten heuristics"
        ],
        "note": "Canonical heuristic set with common references"
      }
    ],
    "relationship_examples": [
      {
        "source": "Material Button",
        "target": "Material Design",

  "quality_scoring": {
    "default_entity_score": 18,
    "default_relationship_score": 15
  },
  "examples": {
    "alias_examples": [
      {
        "canonical": "Pierre Bezukhov",
        "aliases": [
          "Count Bezukhov",
          "Pierre Kirilovich",
          "The Count"
        ],
        "note": "Noble titles become aliases"
      },
      {
        "canonical": "Princess Lise",
        "aliases": [
          "The Little Princess",
          "Lise Bolkonskaya"
        ],
        "note": "Nicknames and epithets become aliases"
      },
      {
        "canonical": "Anna Pavlovna Scherer",
        "aliases": [
          "Annette Scherer",
          "Annette",
          "Anna Pavlovna"
        ],
        "note": "Signature names and diminutives are aliases - Annette is the informal form of Anna"
      }
    ],
    "relationship_examples": [
      {
        "source": "Prince Andrei",
        "target": "Princess Lise",
        "type": "spouse_of",
        "note": "Use spouse_of for marriages"
      },
      {
        "source": "Prince Andrei",
        "target": "Nikolenka",
        "type": "parent_of",
        "note": "Use parent_of for parent-child"
      },
      {
        "source": "Pierre",
        "target": "Prince Andrei",
        "type": "confides_in",
        "note": "Use confides_in when a character shares personal feelings"
      },
      {
        "source": "Pierre",
        "target": "Helene",
        "type": "confronts",
        "note": "Use confronts for direct challenges or accusations"
      },
      {
        "source": "Kutuzov",
        "target": "Bagration",
        "type": "commands",
        "note": "Use commands for military or authority orders"
      },
      {
        "source": "Natasha",
        "target": "Anatole",
        "type": "courts",
        "note": "Use courts for romantic pursuit (Anatole courts Natasha)"
      },
      {
        "source": "Pierre",
        "target": "Napoleon",
        "type": "admires",
        "note": "Use admires for respect or fascination"
      }
    ]
  },

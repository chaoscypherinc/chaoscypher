  "extraction_limits": {
    "max_entity_degree": 40,
    "max_same_source_type": 12,
    "max_relationship_ratio": 8.0,
    "loop_max_entity_count": 50
  },
  "content_exclusions": {
    "categories": [
      "toc",
      "legal",
      "boilerplate",
      "code_blocks",
      "data_tables",
      "advertising",
      "web_artifacts"
    ]
  },
  "extraction_filtering_mode": "lenient",

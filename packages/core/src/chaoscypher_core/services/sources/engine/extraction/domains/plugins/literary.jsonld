{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:literary",
  "name": "literary",
  "version": "1.9.0",
  "description": "Literary texts, fiction, poetry, drama, and literary criticism",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.0,
  "strict_entity_types": true,
  "type_aliases": {
    "Historical Figure": "Character",
    "Historical Event": "Event"
  },
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "literary_core": {
        "terms": [
          "novel",
          "poem",
          "poetry",
          "fiction",
          "narrative",
          "prose",
          "verse",
          "literature",
          "literary"
        ],
        "weight": 1.2
      },
      "narrative_elements": {
        "terms": [
          "protagonist",
          "antagonist",
          "character",
          "plot",
          "narrator",
          "point of view",
          "conflict",
          "resolution",
          "climax"
        ],
        "weight": 1.0
      },
      "literary_devices": {
        "terms": [
          "metaphor",
          "simile",
          "allegory",
          "symbolism",
          "irony",
          "foreshadowing",
          "imagery",
          "allusion",
          "personification",
          "hyperbole"
        ],
        "weight": 1.0
      },
      "genres": {
        "terms": [
          "tragedy",
          "comedy",
          "romance",
          "satire",
          "epic",
          "drama",
          "sonnet",
          "elegy",
          "ode",
          "ballad",
          "haiku",
          "novella",
          "fairy tale"
        ],
        "weight": 0.9
      },
      "book_structure": {
        "terms": [
          "contents",
          "table of contents",
          "prologue",
          "epilogue",
          "preface",
          "foreword",
          "afterword",
          "appendix",
          "dedication"
        ],
        "weight": 1.1
      },
      "narrative_voice": {
        "terms": [
          "he said",
          "she said",
          "they said",
          "i said",
          "he replied",
          "she replied",
          "he thought",
          "she thought",
          "he wondered",
          "she wondered"
        ],
        "weight": 1.0
      },
      "public_domain_sources": {
        "terms": [
          "project gutenberg",
          "gutenberg",
          "public domain",
          "ebook",
          "e-book",
          "transcribed by",
          "produced by"
        ],
        "weight": 1.2
      },
      "publication_terms": {
        "terms": [
          "first published",
          "originally published",
          "printed by",
          "translated by",
          "illustrated by"
        ],
        "weight": 0.8
      }
    },
    "file_extensions": [],
    "doc_types": [
      "literary_text",
      "fiction",
      "poetry",
      "literary_criticism"
    ],
    "patterns": [
      {
        "regex": "(?i)^\\s*(chapter|act|scene|canto)\\s+[IVXivx\\d]+\\b",
        "weight": 1.6,
        "description": "Chapter/Act header at line start"
      },
      {
        "regex": "(?i)\\b(book|part|volume)\\s+(one|two|three|four|five|six|seven|eight|nine|ten|eleven|twelve|[IVXivx\\d]+)\\b",
        "weight": 1.5,
        "description": "Book/Part/Volume divisions"
      },
      {
        "regex": "(?i)\\b(end\\s+of\\s+(?:the\\s+)?(?:chapter|book|volume|part))\\b",
        "weight": 1.2,
        "description": "Explicit section endings"
      },
      {
        "regex": "[\"\\u201c][^\"\\u201d]{10,}[\"\\u201d]\\s*,?\\s*(said|asked|replied|exclaimed|whispered|murmured)\\s+(?:the\\s+)?[A-Z]",
        "weight": 1.5,
        "description": "Dialogue followed by character attribution"
      },
      {
        "regex": "(?i)\\b(said|replied|exclaimed|whispered|murmured|muttered|shouted|cried|asked|answered|responded|inquired|declared|announced|continued)\\b",
        "weight": 0.5,
        "description": "Dialogue tags (high frequency in fiction)"
      },
      {
        "regex": "(?i)\\b(prologue|epilogue|preface|foreword|afterword)\\b",
        "weight": 1.2,
        "description": "Book section markers"
      },
      {
        "regex": "(?i)project\\s+gutenberg",
        "weight": 2.0,
        "description": "Strong signal for public domain classics"
      },
      {
        "regex": "(?i)\\b(once\\s+upon\\s+a\\s+time|in\\s+a\\s+land\\s+far|happily\\s+ever\\s+after)\\b",
        "weight": 1.5,
        "description": "Fairy tale markers"
      },
      {
        "regex": "\\*\\s*\\*\\s*\\*",
        "weight": 0.9,
        "description": "Scene break marker (asterisks)"
      },
      {
        "regex": "(?i)\\bthe\\s+end\\s*\\.?\\s*$",
        "weight": 1.0,
        "description": "Story ending marker"
      }
    ],
    "confidence": {
      "base_score": 0.2,
      "per_keyword_boost": 0.04,
      "extension_boost": 0.0,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.12,
      "max_confidence": 0.95,
      "min_threshold": 0.35
    }
  },
  "entity_exclusions": [
    {
      "description": "Bare titles without names",
      "examples": [
        "Prince",
        "Princess",
        "The Count",
        "The Empress"
      ]
    },
    {
      "description": "Unnamed people",
      "examples": [
        "the old man",
        "the mother",
        "a servant",
        "the footman"
      ]
    },
    {
      "description": "Furniture/atmosphere",
      "examples": [
        "the door",
        "the room",
        "the night",
        "the darkness"
      ]
    },
    {
      "description": "Occupational descriptions",
      "examples": [
        "scarlet-liveried footman",
        "the coachman"
      ]
    }
  ],
  "entity_guidance": "LITERARY EXTRACTION RULES:\n- NAMES: Use canonical names. Put ALL variants (titles, nicknames, transliterations) in aliases.\n- PROPERTIES: Extract ALL relevant attributes - titles, roles, status, relationships, descriptions, dates.\n- FAMILY: Note family positions (eldest son, wife, etc.) as properties.\n\nDO NOT EXTRACT:\n- Structural markers, TOC entries without narrative content\n- Pronouns or vague references\n- Generic objects unless symbolically significant",
  "relationship_guidance": "RELATIONSHIP RULES:\n- EVERY entity MUST have at least 2 relationships — prioritize connecting orphan entities\n- Extract relationships between entities in the same scene, even if implicit\n- Prefer specific relationship types over generic 'related_to'\n- PREFER semantic relationships (spouse_of, parent_of, friendship) over structural ones (appears_in)\n- Use specific family types: spouse_of, parent_of, sibling_of (not has_sister/has_brother), child_of\n- Use friendship for close friends, ally_of for political/military allies\n- Use serves for attendants, governesses, servants, companions\n- Only use ally_of/enemy_of when EXPLICITLY stated in text\n- Limit structural relationships - quality over quantity\n- Use participates_in to connect characters to battles, events, ceremonies (NOT to locations — use located_in for places)\n- Use located_in to connect characters/events to locations. ALWAYS thing→place direction: write 'Character located_in Location', NEVER 'Location located_in Character'.\n- set_in is for Literary Works, Plot Elements, or Events. For 'Character X is in Location Y' use located_in instead of set_in.\n- Use member_of to connect characters to families, military units, social groups\n- Only emit relationship types from the lists above. Do NOT invent new predicates (e.g. avoid 'ruled_by', 'connected_to', 'wants_post_in', 'invincible_against', 'received_by') — pick the closest listed one instead.\n\nINTERACTION SPECIFICITY — use the most specific type that fits:\n- Characters sharing secrets/feelings → confides_in\n- Intellectual argument or disagreement → debates\n- Direct challenge, accusation, or confrontation → confronts\n- Convincing, urging, or appealing → persuades\n- Teaching, instructing, or guiding → mentors\n- Romantic pursuit → courts\n- Emotional support or consolation → comforts\n- Deception or breaking trust → betrays\n- Respect, fascination, or reverence → admires\n- Ridicule or contempt → mocks\n- Military or authority orders → commands\n- Shielding or defending → protects\n- Romantic, social, or political competition → rivals\n- ONLY use interacts_with when NONE of the above specific types apply",
  "templates": {
    "node_templates": [

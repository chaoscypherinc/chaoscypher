{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:political",
  "name": "political",
  "version": "1.10.0",
  "description": "Political documents, governance, policy, and political theory",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.1,
  "strict_entity_types": true,
  "type_aliases": {
    "Politician": "Political Figure",
    "Statesman": "Political Figure",
    "Leader": "Political Figure"
  },
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "governance": {
        "terms": [
          "government",
          "state",
          "policy",
          "legislation",
          "law",
          "constitution",
          "democracy",
          "republic",
          "parliament",
          "congress",
          "senate"
        ],
        "weight": 1.1
      },
      "actors": {
        "terms": [
          "politician",
          "president",
          "prime minister",
          "senator",
          "representative",
          "minister",
          "governor",
          "mayor",
          "diplomat",
          "ambassador"
        ],
        "weight": 1.0
      },
      "concepts": {
        "terms": [
          "sovereignty",
          "rights",
          "liberty",
          "justice",
          "power",
          "authority",
          "legitimacy",
          "citizenship",
          "nationalism",
          "federalism"
        ],
        "weight": 0.9
      },
      "processes": {
        "terms": [
          "election",
          "vote",
          "referendum",
          "campaign",
          "legislation",
          "veto",
          "amendment",
          "ratification",
          "impeachment",
          "inauguration"
        ],
        "weight": 1.0
      },
      "ideologies": {
        "terms": [
          "liberalism",
          "conservatism",
          "socialism",
          "nationalism",
          "populism",
          "authoritarianism",
          "communism",
          "fascism",
          "capitalism",
          "anarchism"
        ],
        "weight": 0.9
      },
      "institutions": {
        "terms": [
          "party",
          "coalition",
          "cabinet",
          "judiciary",
          "executive",
          "legislative",
          "bureaucracy",
          "ministry",
          "agency"
        ],
        "weight": 0.8
      }
    },
    "file_extensions": [],
    "doc_types": [
      "political_document",
      "policy_paper",
      "legislation"
    ],
    "patterns": [
      {
        "regex": "(?i)\\b(president|prime minister|senator|representative|governor|secretary|minister|chancellor)\\s+[A-Z][a-z]+\\b",
        "weight": 1.3,
        "description": "Political titles"
      },
      {
        "regex": "(?i)\\b(act|bill|resolution|executive order)\\s+(of\\s+)?\\d{4}\\b",
        "weight": 1.4,
        "description": "Legislative references"
      },
      {
        "regex": "(?i)\\b(article|section|amendment|clause)\\s+[IVXivx\\d]+\\b",
        "weight": 1.2,
        "description": "Constitutional references"
      },
      {
        "regex": "(?i)\\b(democratic|republican|conservative|liberal|parliament|congress|senate|legislature)\\b",
        "weight": 0.9,
        "description": "Political institutions"
      }
    ],
    "confidence": {
      "base_score": 0.25,
      "per_keyword_boost": 0.04,
      "extension_boost": 0.0,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_exclusions": [
    {
      "description": "Article and section numbers",
      "examples": [
        "Article II",
        "Section 3",
        "Amendment XIV"
      ]
    },
    {
      "description": "Generic references",
      "examples": [
        "the government",
        "lawmakers",
        "the opposition"
      ]
    }
  ],
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- Extract political entities, institutions, figures, parties, and policies\n- Include titles and positions in properties\n- Use formal names with common names as aliases\n\nDO NOT EXTRACT:\n- Article/section numbers: Article II, Section 3, Amendment XIV\n- Generic references: 'the government', 'the opposition', 'lawmakers'\n- Poll numbers or approval ratings as standalone entities\n- Datelines, wire service attributions, or news formatting",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- POWER: Use leads, member_of to show political relationships\n- LEGISLATION: Link laws to enacting bodies with enacts\n- POSITIONS: Use supports, opposes for policy stances\n- AGREEMENTS: Capture treaties with signed relationship\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",
  "templates": {
    "node_templates": [
      {
        "@type": "NodeTemplate",
        "id": "pol_template_entity",
        "name": "Political Entity",
        "description": "A state, nation, or political body",
        "icon": "Flag",
        "color": "#d64164",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "structures",
        "normalization_keywords": [
          "state",
          "nation",
          "country",
          "republic",
          "kingdom",
          "federation"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "pol_template_institution",
        "name": "Institution",
        "description": "A governmental body (parliament, court, agency)",
        "icon": "AccountBalance",
        "color": "#d65641",
        "requires_named_referent": true,
        "quality_score": 18,
        "compatibility_group": "structures",
        "normalization_keywords": [
          "government",
          "parliament",
          "congress",
          "court",
          "ministry",
          "agency",
          "cabinet"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "pol_template_figure",
        "name": "Political Figure",
        "description": "A politician, leader, or political actor",
        "icon": "Person",
        "color": "#d68e41",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "actors",
        "normalization_keywords": [
          "politician",
          "president",
          "prime minister",
          "senator",
          "leader",
          "statesman"
        ],
        "properties": [
          {
            "name": "position",
            "display_name": "Position",
            "property_type": "text",
            "absorbs_types": [
              "Position",
              "Political Position"
            ]
          },
          {
            "name": "party",
            "display_name": "Party Affiliation",
            "property_type": "text"
          },
          {
            "name": "term_dates",
            "display_name": "Term Dates",
            "property_type": "text"
          },
          {
            "name": "constituency",

  },
  "examples": {
    "alias_examples": [
      {
        "canonical": "Franklin Delano Roosevelt",
        "aliases": [
          "FDR",
          "President Roosevelt",
          "Roosevelt"
        ],
        "note": "Initials and titles become aliases"
      },
      {
        "canonical": "Democratic Party",
        "aliases": [
          "Democrats",
          "Dems",
          "DNC"
        ],
        "note": "Short names and abbreviations become aliases"
      }

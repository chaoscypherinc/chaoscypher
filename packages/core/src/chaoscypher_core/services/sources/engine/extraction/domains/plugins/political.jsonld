        "description": "A political party or coalition",
        "icon": "Groups",
        "color": "#d6c641",
        "requires_named_referent": true,
        "quality_score": 18,
        "compatibility_group": "actors",
        "normalization_keywords": [
          "party",
          "coalition",
          "political party",
          "faction"
        ],
        "properties": [
          {
            "name": "ideology",
            "display_name": "Ideology",
            "property_type": "text",
            "absorbs_types": [
              "Party Ideology"
            ]
          },
          {
            "name": "founding_year",
            "display_name": "Founding Year",
            "property_type": "text"
          }
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "pol_template_policy",
        "name": "Policy",

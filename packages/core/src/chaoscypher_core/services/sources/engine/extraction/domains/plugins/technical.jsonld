  "extraction_limits": {
    "max_entity_degree": 20,
    "max_same_source_type": 8,
    "max_relationship_ratio": 6.0,
    "loop_max_entity_count": 30
  },
  "quality_scoring": {
    "default_entity_score": 18,
    "default_relationship_score": 15
  },
  "examples": {
    "alias_examples": [
      {
        "canonical": "requests.Session",
        "aliases": [
          "Session",
          "requests session"
        ],
        "note": "Fully-qualified names and short names become aliases"
      },
      {
        "canonical": "asyncio",
        "aliases": [
          "asyncio module"
        ],
        "note": "Module names are lowercase — preserve original casing"
      }
    ],
    "entity_examples": [
      {
        "name": "asyncio",
        "type": "Module",
        "note": "Python module names are lowercase — this is correct"
      },
      {
        "name": "PEP 484",
        "type": "Specification",
        "note": "PEPs and RFCs are Specification entities"
      },
      {
        "name": "StopIteration",
        "type": "Exception",
        "note": "Exception class with PascalCase name"
      },
      {
        "name": "contextmanager",
        "type": "Decorator",
        "note": "Decorator names are lowercase"
      }
    ],
    "relationship_examples": [
      {
        "source": "UserService",
        "target": "BaseService",
        "type": "inherits_from",
        "note": "Use inherits_from for class inheritance"
      },
      {
        "source": "PEP 484",
        "target": "typing",
        "type": "specifies",
        "note": "PEP specifies the module it defines"
      },
      {
        "source": "test_login",
        "target": "LoginHandler",
        "type": "tests",
        "note": "Use tests for test-to-code relationships"
      }
    ]

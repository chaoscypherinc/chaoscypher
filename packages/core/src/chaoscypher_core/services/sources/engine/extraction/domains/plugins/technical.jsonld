{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:technical",
  "name": "technical",
  "version": "1.9.0",
  "description": "Technical documentation, code, APIs, and software libraries",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.2,
  "strict_entity_types": true,
  "type_aliases": {
    "Func": "Function",
    "API": "Endpoint",
    "Lib": "Package",
    "Library": "Package",
    "Var": "Constant",
    "Variable": "Constant"
  },
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "code": {
        "terms": [
          "def ",
          "class ",
          "function",
          "import ",
          "return",
          "async ",
          "await ",
          "const ",
          "var ",
          "let "
        ],
        "weight": 1.0
      },
      "api": {
        "terms": [
          "endpoint",
          "request",
          "response",
          "rest",
          "api",
          "get",
          "post",
          "patch",
          "delete",
          "http",
          "json"
        ],
        "weight": 0.8
      },
      "tech": {
        "terms": [
          "module",
          "package",
          "library",
          "framework",
          "parameter",
          "exception",
          "method",
          "attribute",
          "instance",
          "constructor"
        ],
        "weight": 0.6
      }
    },
    "file_extensions": [
      ".py",
      ".js",
      ".ts",
      ".rst",
      ".html",
      ".md",
      ".jsx",
      ".tsx"
    ],
    "doc_types": [
      "sphinx_html",
      "markdown",
      "openapi"
    ],
    "patterns": [
      {
        "regex": "```[\\w]*\\n",
        "weight": 1.5,
        "description": "Code blocks in markdown"
      }
    ],
    "confidence": {
      "base_score": 0.3,
      "per_keyword_boost": 0.05,
      "extension_boost": 0.1,
      "doc_type_boost": 0.2,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_exclusions": [
    {
      "description": "Generic variable names",
      "examples": [
        "x",
        "temp",
        "result",
        "data",
        "i",
        "j"
      ]
    }
  ],
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- Extract modules, classes, functions, methods, exceptions, and parameters\n- Use canonical names: 'asyncio', 'collections.abc', 'StopIteration' (preserve original casing)\n- Technical entity names are typically lowercase (e.g., 'asyncio', 'dataclass', 'contextmanager') — this is correct\n- Include type hints and return types in descriptions\n- Extract PEPs and RFCs as Specification entities (e.g., 'PEP 484', 'RFC 7231')\n\nDO NOT EXTRACT:\n- Code syntax: brackets, parentheses, operators\n- Generic variable names: 'x', 'temp', 'result', 'data'\n- Built-in primitive types as standalone entities: str, int, list, dict, bool\n- Line numbers or file paths as entities\n- Glossary section headings or navigation labels",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- HIERARCHY: Use contains for module->class->method relationships\n- INHERITANCE: Always capture inherits_from for base classes\n- SIGNATURES: Extract parameters with has_parameter, return types with returns\n- ERRORS: Link exceptions with raises relationship\n- SPECIFICATIONS: Link PEPs/RFCs to what they define using 'specifies' relationship\n- Avoid creating many relationships between the same two entities — one relationship per concept\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",
  "templates": {
    "node_templates": [
      {
        "@type": "NodeTemplate",
        "id": "system_template_module",
        "name": "Module",
        "description": "Python module or code package",
        "icon": "Inventory2",
        "color": "#d64178",
        "requires_named_referent": false,
        "quality_score": 25,
        "compatibility_group": "code_elements",
        "normalization_keywords": [
          "a module",
          "module for",
          "module containing",
          "this module",
          "python module",
          "provides functions"
        ],
        "properties": [
          {
            "name": "author",
            "display_name": "Author",
            "property_type": "text",
            "absorbs_types": [
              "Person",
              "Author",
              "Creator"
            ]
          }
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "system_template_class",
        "name": "Class",
        "description": "Object-oriented class definition",
        "icon": "DataObject",
        "color": "#d64a41",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "code_elements",

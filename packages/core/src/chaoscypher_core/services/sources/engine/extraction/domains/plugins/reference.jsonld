{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:reference",
  "name": "reference",
  "version": "1.9.1",
  "description": "Standards documents (RFC / ISO / IEEE / W3C / ANSI / ECMA), technical specifications, API references, user / administrator / operator manuals, configuration guides, and release notes",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.2,
  "strict_entity_types": true,
  "type_aliases": {
    "Spec": "Specification",
    "User Guide": "Manual",
    "Admin Guide": "Manual",
    "Administrator Guide": "Manual",
    "Reference Guide": "Manual",
    "Configuration Guide": "Manual",
    "Operator Manual": "Manual",
    "Installation Guide": "Manual",
    "Troubleshooting Guide": "Manual",
    "Argument": "Parameter",
    "Option": "Parameter",
    "Flag": "Parameter",
    "Setting": "Configuration Item",
    "RFC Document": "Standard",
    "Subsection": "Section",
    "Clause": "Section",
    "Annex": "Section",
    "Appendix": "Section"
  },
  "entity_exclusions": [
    {
      "description": "Standalone normative keywords without context",
      "examples": [
        "MUST",
        "SHALL",
        "SHOULD",
        "MAY",
        "REQUIRED"
      ]
    },
    {
      "description": "Bare section markers without title",
      "examples": [
        "Section 4",
        "§4.2",
        "Appendix A",
        "Annex B"
      ]
    },
    {
      "description": "Generic doc references",
      "examples": [
        "the document",
        "this specification",
        "this manual",
        "the standard",
        "the reference"
      ]
    },
    {
      "description": "Boilerplate page furniture",
      "examples": [
        "page 1 of 10",
        "see footnote",
        "table of contents",
        "copyright notice"
      ]
    }
  ],
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "standards_core": {
        "terms": [
          "RFC",
          "ISO",
          "IEEE",
          "ANSI",
          "ECMA",
          "W3C",
          "IETF",
          "BCP",
          "FIPS",
          "NIST",
          "JSR",
          "IEC",
          "OASIS",
          "Khronos",
          "ITU-T",
          "ETSI"
        ],
        "weight": 1.3
      },
      "normative_language": {
        "terms": [
          "MUST",
          "MUST NOT",
          "SHALL",
          "SHALL NOT",
          "SHOULD",
          "SHOULD NOT",
          "MAY",
          "RECOMMENDED",
          "REQUIRED",
          "OPTIONAL",
          "NOT RECOMMENDED",
          "normative",
          "informative",
          "conformance"
        ],
        "weight": 1.4
      },
      "spec_structure": {
        "terms": [
          "section",
          "clause",
          "subsection",
          "appendix",
          "annex",
          "errata",
          "abstract",
          "conformance",
          "requirements",
          "scope",
          "references",
          "normative references",
          "informative references"
        ],
        "weight": 1.1
      },
      "reference_doc": {
        "terms": [
          "reference manual",
          "user guide",
          "user manual",
          "operator manual",
          "administrator guide",
          "administration guide",
          "configuration guide",
          "installation guide",
          "troubleshooting guide",
          "release notes",
          "changelog",
          "API reference",
          "developer guide",
          "implementation guide"
        ],
        "weight": 1.3
      },
      "api_terms": {
        "terms": [
          "endpoint",
          "parameter",
          "argument",
          "return value",
          "return type",
          "raises",
          "throws",
          "exception",
          "deprecated",
          "since version",
          "available since",
          "introduced in",
          "see also",
          "syntax",
          "signature",
          "OpenAPI",
          "Swagger",
          "JSON Schema",
          "AsyncAPI",
          "GraphQL schema",
          "WSDL",
          "OpenRPC"
        ],
        "weight": 1.0
      },
      "procedure_terms": {
        "terms": [
          "step",
          "procedure",
          "prerequisite",
          "post-condition",
          "preconditions",
          "output",
          "exit code",
          "return code",
          "install",
          "configure",
          "troubleshoot",
          "verify",
          "uninstall",
          "rollback"
        ],
        "weight": 1.0
      },
      "compliance_terms": {
        "terms": [
          "conformance class",
          "compliance",
          "certified",
          "validated",
          "audit",
          "accreditation",
          "profile",
          "conformance level",
          "conformance criterion",
          "interoperability"
        ],
        "weight": 1.0
      },
      "glossary_terms": {
        "terms": [
          "glossary",
          "terminology",
          "definitions",
          "defined terms",
          "abbreviations",
          "acronyms",
          "terms used in this document"
        ],
        "weight": 0.9
      }
    },
    "file_extensions": [
      ".txt",
      ".pdf",
      ".html",
      ".xml",
      ".rst",
      ".md"
    ],
    "doc_types": [
      "rfc",
      "iso_standard",
      "ieee_standard",
      "w3c_recommendation",
      "api_reference",
      "user_manual",
      "admin_guide",
      "configuration_guide",
      "technical_reference",
      "specification",
      "release_notes",
      "openapi_spec"
    ],
    "patterns": [
      {
        "regex": "(?i)\\bRFC\\s*\\d{3,5}\\b",
        "weight": 1.6,
        "description": "RFC number references"
      },
      {
        "regex": "\\bISO(?:[/\\s-](?:IEC|TS|TR))?\\s*\\d{3,6}(?:[-:]\\d+)*\\b",
        "weight": 1.6,
        "description": "ISO / ISO-IEC standard numbers"
      },
      {
        "regex": "\\bIEEE\\s*(?:Std\\.?\\s*)?\\d{3,4}(?:\\.\\d+)*\\b",
        "weight": 1.5,
        "description": "IEEE standard numbers"
      },
      {
        "regex": "\\b(?:ECMA|JSR|FIPS|NIST\\s+SP|ITU-T\\s+[A-Z])[-\\s]?\\d+(?:\\.\\d+)*\\b",
        "weight": 1.5,
        "description": "ECMA / JSR / FIPS / NIST SP / ITU-T standard numbers"
      },
      {
        "regex": "\\b(?:MUST|SHALL|MAY|REQUIRED|RECOMMENDED|OPTIONAL)(?:\\s+NOT)?\\b",
        "weight": 1.3,
        "description": "RFC 2119 normative keywords (strict caps)"
      },
      {
        "regex": "(?i)\\bsee\\s+(?:section|clause|annex|appendix|chapter)\\s+[\\dA-Z]+(?:\\.[\\dA-Z]+)*",
        "weight": 1.1,
        "description": "Cross-references to numbered sections"
      },
      {
        "regex": "(?i)\\b(?:deprecated|since|available\\s+(?:in|since)|introduced\\s+in|removed\\s+in)\\s+(?:version\\s*)?\\d+(?:\\.\\d+)+\\b",
        "weight": 1.2,
        "description": "Version-pinned API doc markers"
      },
      {
        "regex": "https?://(?:www\\.)?w3\\.org/TR/",
        "weight": 1.6,
        "description": "W3C TR (technical recommendation) URLs"
      },
      {
        "regex": "https?://(?:datatracker|tools)\\.ietf\\.org/(?:doc|html)/rfc\\d+",
        "weight": 1.6,
        "description": "IETF Datatracker / tools.ietf.org RFC URLs"
      },
      {
        "regex": "\\b[a-z][a-z0-9_-]+\\(\\d{1,2}\\)\\b",
        "weight": 1.2,
        "description": "Unix manpage references (e.g., printf(3), ls(1))"
      }
    ],
    "confidence": {
      "base_score": 0.25,
      "per_keyword_boost": 0.04,
      "extension_boost": 0.05,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- Extract named standards by their canonical identifier: 'RFC 7231', 'ISO/IEC 27001:2022', 'IEEE 802.11', 'W3C HTML 5.2'\n- Extract standards bodies by full name with abbreviation as alias: 'Internet Engineering Task Force' (IETF), 'International Organization for Standardization' (ISO)\n- Extract sections with their number and (when present) heading text: 'Section 4.2', 'Section 4.2: Cache-Control'\n- Extract normative requirements as Requirement entities with the imperative verb (MUST / SHALL / SHOULD) as a property; quote the requirement statement when possible\n- Extract procedures (install, configure, troubleshoot) and their ordered steps\n- Extract documented API entries (function/endpoint references) and their parameters with type, default, required/optional\n- Extract glossary terms by the defined term as the entity name; put the definition in a property\n- Extract configuration items by canonical key with default value as a property\n\nDO NOT EXTRACT:\n- Standalone normative words ('MUST', 'SHALL') as entities — they are properties of requirements\n- Bare section markers without heading text ('Section 4' alone)\n- Generic references: 'the document', 'this specification', 'this manual'\n- Page furniture: page numbers, footers, table-of-contents markers",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- PUBLICATION: Use published_by for standard-to-body, references for standard-to-standard citations\n- LIFECYCLE: Use supersedes / superseded_by for replaced standards, obsoletes for deprecation chains\n- STRUCTURE: Use has_section for standard-to-section, part_of_section for subsection-to-section, defined_in for requirement/term-to-section\n- NORMATIVE: Use specifies for standard-to-requirement, requires for requirement-to-requirement dependency, conforms_to for product-to-standard\n- DOCUMENTATION: Use documents for manual-to-product, references_standard for manual-to-standard\n- PROCEDURE: Use contains_step for procedure-to-step, precedes / follows for step ordering\n- API: Use has_parameter for api/procedure-to-parameter, raises for procedure/api-to-error, defines_term for standard/manual-to-glossary-term\n- VERSIONING: Use introduced_in / deprecated_in / removed_in for api/parameter to version\n- TERMS: Use defines_term for source-to-glossary-term\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",
  "templates": {
    "node_templates": [
      {
        "@type": "NodeTemplate",
        "id": "ref_template_standard",
        "name": "Standard",
        "description": "A named standards document (RFC, ISO, IEEE, W3C Recommendation, ANSI, ECMA, FIPS, JSR)",
        "icon": "MenuBook",
        "color": "#41d65d",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "documents",
        "normalization_keywords": [
          "RFC",
          "ISO",
          "IEEE",
          "ANSI",
          "ECMA",
          "FIPS",
          "JSR",
          "W3C Recommendation",
          "standard",
          "international standard"
        ],
        "properties": [
          {
            "name": "identifier",
            "display_name": "Standard Identifier",
            "property_type": "text",
            "absorbs_types": [
              "Standard Identifier",
              "Standard Number",
              "Document Number"
            ]
          },
          {
            "name": "status",
            "display_name": "Status",
            "property_type": "text",
            "absorbs_types": [
              "Status",
              "Standard Status"
            ]
          },
          {
            "name": "date_published",
            "display_name": "Date Published",
            "property_type": "date",
            "absorbs_types": [
              "Date Published",
              "Publication Date"
            ]
          },
          {
            "name": "edition",
            "display_name": "Edition",
            "property_type": "text",
            "absorbs_types": [
              "Edition",
              "Revision"
            ]
          }
        ]
      },
      {

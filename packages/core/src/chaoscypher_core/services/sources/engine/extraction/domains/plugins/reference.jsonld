        "icon": "AccountBalance",
        "color": "#41d6b3",
        "requires_named_referent": true,
        "quality_score": 22,
        "compatibility_group": "people",
        "normalization_keywords": [
          "standards body",
          "standards organization",
          "working group",
          "consortium",
          "committee",
          "task force",
          "alliance"
        ],
        "properties": [
          {
            "name": "abbreviation",
            "display_name": "Abbreviation",
            "property_type": "text",
            "absorbs_types": [

  "examples": {
    "alias_examples": [
      {
        "canonical": "Request for Comments 2616",
        "aliases": [
          "RFC 2616",
          "HTTP/1.1",
          "the HTTP spec"
        ],
        "note": "RFC numbers and the protocol they specify become aliases of the canonical RFC name"
      },
      {
        "canonical": "International Organization for Standardization",
        "aliases": [
          "ISO",
          "the ISO"
        ],
        "note": "Standards bodies with common abbreviations"
      },
      {
        "canonical": "ISO/IEC 27001:2022",
        "aliases": [
          "ISO 27001",
          "27001:2022"
        ],
        "note": "Standards with edition suffix; capture identifier as a property and use full canonical form as the entity name"
      }
    ],
    "relationship_examples": [
      {
        "source": "RFC 7231",
        "target": "RFC 2616",
        "type": "supersedes",
        "note": "Use supersedes for newer RFC replacing older one (and superseded_by in the inverse direction)"
      },
      {
        "source": "HTTP/1.1",
        "target": "IETF",
        "type": "published_by",
        "note": "Use published_by for standard-to-body"
      },
      {
        "source": "Section 5.3: Cache-Control",
        "target": "RFC 7234",
        "type": "defined_in",
        "note": "Cache-Control requirement defined in section 5.3 of RFC 7234"
      },
      {
        "source": "PostgreSQL Administrator's Guide",
        "target": "PostgreSQL 16",
        "type": "documents",
        "note": "Use documents for manual-to-product"
      }
    ],
    "entity_examples": [
      {
        "type": "Standard",
        "examples": [
          "RFC 7231",
          "RFC 2119",
          "ISO/IEC 27001:2022",
          "IEEE 802.11ax",
          "W3C HTML 5.2",
          "ECMA-262"
        ]
      },
      {
        "type": "Standards Body",
        "examples": [
          "IETF",
          "ISO",
          "IEEE",
          "W3C",
          "ANSI",
          "ECMA International",
          "OASIS",
          "Khronos Group",
          "NIST"
        ]
      }
    ]
  },
  "quality_scoring": {
    "default_entity_score": 18,
    "default_relationship_score": 15
  },
  "title_words": [
    "the",
    "of",
    "and",
    "an",
    "rfc",
    "iso",
    "ieee",
    "ansi",
    "ecma",
    "w3c",
    "std",
    "section",
    "appendix",
    "annex",
    "chapter",
    "part"
  ],
  "extraction_limits": {
    "max_entity_degree": 25,
    "max_same_source_type": 12,
    "max_relationship_ratio": 8.0,
    "loop_max_entity_count": 40
  },
  "content_exclusions": {
    "categories": [
      "toc",
      "legal",
      "boilerplate",
      "web_artifacts",
      "advertising"
    ]
  },
  "extraction_filtering_mode": "balanced",
  "icon": "MenuBook"
}

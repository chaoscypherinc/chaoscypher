  "examples": {
    "alias_examples": [
      {
        "canonical": "Central Intelligence Agency",
        "aliases": [
          "CIA",
          "the Agency",
          "Langley"
        ],
        "note": "Agency full names with abbreviations and common references become aliases"
      },
      {
        "canonical": "Project Blue Book",
        "aliases": [
          "Blue Book",
          "BB"
        ],
        "note": "Named programs with common shorthand"
      },
      {
        "canonical": "Unidentified Aerial Phenomenon",
        "aliases": [
          "UAP",
          "UFO",
          "unidentified object"
        ],
        "note": "UAP and UFO refer to the same phenomenon category"
      }
    ],
    "relationship_examples": [
      {
        "source": "Tic Tac Encounter Report",
        "target": "Commander David Fravor",
        "type": "sighted_by",
        "note": "Use sighted_by for sighting-to-witness connections"
      },
      {
        "source": "Tic Tac Encounter Report",
        "target": "AN/APG-73 radar",
        "type": "observed_via",
        "note": "Use observed_via for sighting-to-sensor connections"
      },
      {
        "source": "AATIP",
        "target": "Defense Intelligence Agency",
        "type": "operated_by",
        "note": "Use operated_by for program-to-agency connections"
      },
      {
        "source": "Project Blue Book Special Report 14",
        "target": "FOIA Case F-2017-00876",
        "type": "released_under",
        "note": "Use released_under to link a document to the FOIA case under which it was released"
      }
    ]
  },
  "quality_scoring": {
    "default_entity_score": 18,
    "default_relationship_score": 15
  },
  "title_words": [
    "mr",
    "mrs",
    "ms",
    "miss",
    "dr",
    "sir",
    "the",
    "of",
    "de",
    "von",

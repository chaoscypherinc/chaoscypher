    "lieutenant",
    "captain",
    "commander",
    "major",
    "sergeant",
    "admiral",
    "secretary",
    "assistant secretary",
    "undersecretary"
  ],
  "extraction_limits": {
    "max_entity_degree": 25,
    "max_same_source_type": 10,
    "max_relationship_ratio": 8.0,
    "loop_max_entity_count": 40
  },
  "content_exclusions": {
    "categories": [
      "toc",
      "legal",
      "boilerplate",
      "web_artifacts",
      "advertising"
    ]
  },
  "extraction_filtering_mode": "strict",
  "icon": "Visibility"
}

{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:intelligence",
  "name": "intelligence",
  "version": "2.1.0",
  "description": "Declassified intelligence documents, FOIA releases, intelligence briefings, agency cables, dossiers, UAP/UFO reports, and intelligence-community products",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.3,
  "strict_entity_types": true,
  "type_aliases": {
    "UAP": "Anomalous Object",
    "UFO": "Anomalous Object",
    "Craft": "Anomalous Object",
    "Object": "Anomalous Object",
    "Eyewitness": "Witness",
    "Observer": "Witness",
    "Asset": "Source",
    "Informant": "Source",
    "Defector": "Source"
  },
  "entity_exclusions": [
    {
      "description": "Generic intelligence boilerplate",
      "examples": [
        "this document",
        "the report",
        "classified information",
        "intelligence community"
      ]
    },
    {
      "description": "Standalone redaction markers without context",
      "examples": [
        "[REDACTED]",
        "(b)(1)",
        "(b)(3)",
        "DELETED"
      ]
    },
    {
      "description": "Generic role references without names",
      "examples": [
        "the analyst",
        "an officer",
        "the source",
        "the witness"
      ]
    }
  ],
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "classification": {
        "terms": [
          "declassified",
          "classified",
          "top secret",
          "secret",
          "confidential",
          "NOFORN",
          "FOUO",
          "SCI",
          "compartmented",
          "sanitized",
          "FOIA",
          "MORI",
          "freedom of information",
          "originator controlled",
          "ORCON"
        ],
        "weight": 1.4
      },
      "intelligence_core": {
        "terms": [
          "intelligence",
          "briefing",
          "dossier",
          "memorandum",
          "cable",
          "debrief",
          "tradecraft",
          "collection",
          "analyst",
          "finished intelligence",
          "raw intelligence",
          "indications and warning",
          "all-source",
          "estimate",
          "assessment"
        ],
        "weight": 1.3
      },
      "uap_core": {
        "terms": [
          "UFO",
          "UAP",
          "unidentified",
          "anomalous",
          "unexplained",
          "sighting",
          "encounter",
          "foo fighter",
          "flying disc",
          "flying saucer",
          "unidentified aerial phenomena",
          "hovering",
          "luminous object",
          "occupants",
          "non-human"
        ],
        "weight": 1.3
      },
      "observation": {
        "terms": [
          "witness",
          "observer",
          "observed",
          "pilot report",
          "radar return",
          "radar contact",
          "visual contact",
          "FLIR",
          "gun camera",
          "telescope",
          "tracked",
          "intercepted visually",
          "ground observer"
        ],
        "weight": 1.1
      },
      "sources": {
        "terms": [
          "HUMINT",
          "SIGINT",
          "IMINT",
          "OSINT",
          "ELINT",
          "MASINT",
          "GEOINT",
          "TECHINT",
          "informant",
          "defector",
          "intercept",
          "source coded"
        ],
        "weight": 1.0
      },
      "agencies": {
        "terms": [
          "CIA",
          "DIA",
          "NSA",
          "FBI",
          "NRO",
          "AFOSI",
          "ONI",
          "INR",
          "DOE",
          "Project Blue Book",
          "AATIP",
          "AAWSAP",
          "GRU",
          "KGB",
          "MI6",
          "MI5",
          "Mossad",
          "Sixth Directorate"
        ],
        "weight": 1.0
      },
      "redaction_markers": {
        "terms": [
          "redacted",
          "blacked out",
          "exemption",
          "withheld",
          "page denied",
          "glomar",
          "Vaughn index",
          "in part",
          "in full"
        ],
        "weight": 1.2
      },
      "operations": {
        "terms": [
          "operation",
          "program",
          "project",
          "task force",
          "code name",
          "cryptonym",
          "covert action",
          "surveillance",
          "reconnaissance",
          "exfiltration",
          "compartment"
        ],
        "weight": 1.0
      }
    },
    "file_extensions": [
      ".pdf",
      ".txt",
      ".tif",
      ".tiff"
    ],
    "doc_types": [
      "briefing",
      "cable",
      "memorandum",
      "intelligence_report",
      "dossier",
      "declassified_document",
      "foia_release",
      "uap_report",
      "national_intelligence_estimate",
      "presidents_daily_brief"
    ],
    "patterns": [
      {
        "regex": "(?i)\\b(TOP\\s+SECRET|SECRET|CONFIDENTIAL)(?://[A-Z/\\s-]+)?\\b",
        "weight": 1.6,
        "description": "Classification banner markings"
      },
      {
        "regex": "(?i)\\bFOIA\\s+(?:Case|Request)\\s*(?:No|#)?[.:)?\\s]*[A-Z0-9\\-/]+",
        "weight": 1.5,
        "description": "FOIA case/request numbers"
      },
      {
        "regex": "\\[\\s*REDACTED\\s*\\]|\\(b\\)\\(\\d+\\)",
        "weight": 1.4,
        "description": "Redaction blocks and FOIA exemption codes"
      },
      {
        "regex": "(?i)\\b(?:derived\\s+from|declassify\\s+on|classified\\s+by|reason)\\s*[:.]",
        "weight": 1.3,
        "description": "Classification authority markings"
      },
      {
        "regex": "(?i)\\b(UAP|UFO|flying\\s+saucer|flying\\s+disc|unidentified\\s+aerial)\\b",
        "weight": 1.5,
        "description": "UAP/UFO term references"
      },
      {
        "regex": "(?i)//\\s*(?:NOFORN|ORCON|REL\\s+TO|FOUO|FVEY|EYES\\s+ONLY)\\b",
        "weight": 1.4,
        "description": "Compartment / dissemination control markings"
      },
      {
        "regex": "(?i)\\b(?:SITREP|FLASH|IMMEDIATE|ROUTINE|PRIORITY)\\b\\s*[/-]?\\s*(?:cable|message)?",
        "weight": 1.0,
        "description": "Cable precedence indicators"
      },
      {
        "regex": "(?i)\\b(?:MEMORANDUM\\s+FOR|FROM)[:\\s]+(?:THE\\s+)?(?:DIRECTOR|DEPUTY|CHIEF|ASSISTANT)\\b",
        "weight": 1.3,
        "description": "Memo header lines"
      }
    ],
    "confidence": {
      "base_score": 0.25,
      "per_keyword_boost": 0.04,
      "extension_boost": 0.1,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- ALWAYS extract the document being analyzed as its own entity — Intelligence Report for briefings/dossiers/assessments/FOIA releases, Cable for diplomatic or agency messages. Use the document's title (or its first descriptive line when no title is present) as the name. This anchor is mandatory because the document-level predicates (mentions, classified_as, released_under, references) must originate from an Intelligence Report or Cable entity to land in the graph; without it the relationships are silently dropped at the type-constraint stage.\n- Extract intelligence agencies, programs, and operations with codenames when present\n- Extract sources by collection discipline (HUMINT, SIGINT, IMINT, OSINT) when stated; attach the discipline as a property\n- Extract sightings with date, location, duration, and sensor where available\n- Extract anomalous objects with shape, behavior, color, and observed signature as properties\n- Extract classification markings (TS, SECRET, SCI, NOFORN) as their own entities only when discussed as such, not for every paragraph banner\n- Extract intelligence reports/cables with originator, classification, and date\n- Extract witnesses with role (pilot, radar operator, civilian, ground observer) as a property\n- Treat agency abbreviations (CIA, DIA, AFOSI) as aliases of their full names\n\nDO NOT EXTRACT:\n- Page-level classification banners as entities (use as document property only)\n- Standalone redaction markers ([REDACTED], (b)(1), (b)(3))\n- Generic role references without names ('the analyst', 'an officer', 'the source')\n- Boilerplate distribution and handling instructions",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- OBSERVATION: Use sighted_by for witness-to-sighting, observed_via for sensor-to-sighting, occurred_at for sighting-to-location\n- CLASSIFICATION: Use classified_as for document-to-marking, released_under for document-to-FOIA-case, redacted_in for marking-to-document\n- ATTRIBUTION: Use sourced_from for report-to-source, authored for person-to-report, briefed for person-to-document\n- ORGANIZATION: Use operated_by for program-to-agency, conducted_by for operation-to-agency, assigned_to for person-to-program/operation\n- ANALYSIS: Use corroborated_by for sighting/report cross-references, references for document-to-document citations, mentions for report-to-entity\n- RECOVERY: Use recovered for agency/person-to-anomalous-object\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",
  "templates": {
    "node_templates": [
      {
        "@type": "NodeTemplate",
        "id": "intel_template_person",
        "name": "Person",
        "description": "A person named in an intelligence document: officer, official, analyst, dignitary",
        "icon": "Person",
        "color": "#41d688",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "people",
        "normalization_keywords": [
          "person",
          "individual",
          "officer",
          "official",
          "analyst",
          "director",
          "deputy",
          "chief",
          "secretary",
          "ambassador",
          "attaché"

{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:educational",
  "name": "educational",
  "version": "1.11.0",
  "description": "Educational materials, textbooks, courses, and instructional content",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.1,
  "strict_entity_types": true,
  "type_aliases": {
    "Teacher": "Educator"
  },
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "educational_core": {
        "terms": [
          "learn",
          "teach",
          "education",
          "instruction",
          "lesson",
          "course",
          "curriculum",
          "student",
          "teacher",
          "classroom"
        ],
        "weight": 1.1
      },
      "learning_objectives": {
        "terms": [
          "learning objective",
          "by the end of",
          "students will be able to",
          "understand",
          "demonstrate",
          "apply",
          "analyze",
          "evaluate"
        ],
        "weight": 1.2
      },
      "structure": {
        "terms": [
          "chapter",
          "unit",
          "module",
          "section",
          "topic",
          "concept",
          "principle",
          "definition",
          "key terms"
        ],
        "weight": 0.9
      },
      "pedagogy": {
        "terms": [
          "exercise",
          "practice",
          "quiz",
          "test",
          "exam",
          "assessment",
          "homework",
          "assignment",
          "project",
          "activity"
        ],
        "weight": 1.0
      },
      "prerequisites": {
        "terms": [
          "prerequisite",
          "prior knowledge",
          "required",
          "before learning",
          "background",
          "foundation",
          "builds on"
        ],
        "weight": 0.9
      },
      "examples": {
        "terms": [
          "example",
          "for instance",
          "consider",
          "illustration",
          "case study",
          "scenario",
          "demonstration"
        ],
        "weight": 0.7
      }
    },
    "file_extensions": [
      ".pdf"
    ],
    "doc_types": [
      "textbook",
      "course_material",
      "educational_content"
    ],
    "patterns": [
      {
        "regex": "(?i)\\b(chapter|unit|module|lesson|section)\\s+\\d+\\b",
        "weight": 1.3,
        "description": "Educational structure"
      },
      {
        "regex": "(?i)\\blearning\\s+objective[s]?\\s*:?\\b",
        "weight": 1.5,
        "description": "Learning objectives header"
      },
      {
        "regex": "(?i)\\b(exercise|problem|question|activity)\\s+\\d+\\b",
        "weight": 1.2,
        "description": "Exercise numbering"
      },
      {
        "regex": "(?i)\\b(key\\s+terms?|vocabulary|glossary|summary|review)\\s*:?\\b",
        "weight": 1.0,
        "description": "Educational sections"
      },
      {
        "regex": "(?i)\\b(students?\\s+will|by\\s+the\\s+end|after\\s+completing)\\b",
        "weight": 1.1,
        "description": "Objective language"
      }
    ],
    "confidence": {
      "base_score": 0.25,
      "per_keyword_boost": 0.04,
      "extension_boost": 0.1,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_exclusions": [
    {
      "description": "Structural markers",
      "examples": [
        "Chapter 1",
        "Unit 3",
        "Exercise 2a",
        "Lesson 5"
      ]
    },
    {
      "description": "Instructional boilerplate",
      "examples": [
        "In this chapter you will learn",
        "Key takeaways"
      ]
    },
    {
      "description": "Generic student references",
      "examples": [
        "the student",
        "learners",
        "you"
      ]
    }
  ],
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- Extract concepts, learning objectives, prerequisites, and assessments\n- Include subject areas and difficulty levels in properties\n- Use clear, descriptive names for concepts\n\nDO NOT EXTRACT:\n- Structural markers: Chapter 1, Unit 3, Lesson 5, Exercise 2a\n- Instructional boilerplate: 'In this chapter you will learn', 'Key takeaways'\n- Generic student references: 'the student', 'learners', 'you'\n- Page numbers, answer keys, or index references",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- PROGRESSION: Use requires, builds_on to show learning dependencies\n- OBJECTIVES: Link lessons to objectives with teaches relationship\n- PRACTICE: Connect exercises to concepts with practices\n- ASSESSMENT: Link assessments to objectives with assessed_by\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",
  "templates": {
    "node_templates": [
      {
        "@type": "NodeTemplate",
        "id": "edu_template_concept",
        "name": "Concept",
        "description": "A key concept or idea to be learned",
        "icon": "Lightbulb",
        "color": "#d6d141",
        "requires_named_referent": false,
        "quality_score": 25,
        "compatibility_group": "content",
        "normalization_keywords": [
          "concept",
          "idea",
          "principle",
          "topic",
          "subject matter"
        ],
        "properties": [
          {
            "name": "difficulty_level",
            "display_name": "Difficulty Level",
            "property_type": "text",
            "absorbs_types": [

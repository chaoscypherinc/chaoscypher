  "extraction_limits": {
    "max_entity_degree": 20,
    "max_same_source_type": 8,
    "max_relationship_ratio": 6.0,
    "loop_max_entity_count": 35
  },
  "quality_scoring": {
    "default_entity_score": 18,
    "default_relationship_score": 15
  },
  "title_words": [
    "mr",
    "mrs",
    "ms",
    "miss",
    "dr",
    "sir",
    "dame",
    "madam",
    "the",
    "of",
    "de",
    "von",
    "van",
    "professor",
    "dean",
    "chancellor",
    "provost"
  ],
  "examples": {
    "alias_examples": [
      {
        "canonical": "Pythagorean Theorem",
        "aliases": [
          "Pythagoras' Theorem",
          "a� + b� = c�"
        ],
        "note": "Alternate names and symbolic forms become aliases"
      },
      {
        "canonical": "Newton's Second Law",
        "aliases": [
          "F = ma",
          "Second Law of Motion"
        ],
        "note": "Equations and formal names become aliases"
      }
    ],
    "relationship_examples": [
      {
        "source": "Module 3",
        "target": "Concept: Derivatives",
        "type": "teaches",
        "note": "Use teaches for module-concept links"
      },
      {
        "source": "Algebra",
        "target": "Calculus",
        "type": "requires",
        "note": "Use requires for prerequisite relationships"
      }
    ]
  },
  "content_exclusions": {
    "categories": [
      "toc",
      "legal",
      "boilerplate",
      "web_artifacts",
      "advertising"
    ]
  },
  "extraction_filtering_mode": "balanced",
  "icon": "School"
}

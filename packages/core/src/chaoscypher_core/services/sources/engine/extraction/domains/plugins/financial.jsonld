{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:financial",
  "name": "financial",
  "version": "1.11.0",
  "description": "Financial documents, market analysis, investment, and economic reports",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.2,
  "strict_entity_types": true,
  "type_aliases": {
    "Stock": "Financial Instrument",
    "Equity": "Financial Instrument",
    "Share": "Financial Instrument",
    "SEC": "Regulator",
    "FINRA": "Regulator",
    "CFTC": "Regulator"
  },
  "entity_exclusions": [
    {
      "description": "Raw numbers alone",
      "examples": [
        "$5M",
        "15%",
        "Q3 2024"
      ]
    },
    {
      "description": "Boilerplate disclaimers",
      "examples": [
        "past performance",
        "not financial advice",
        "forward-looking statements"
      ]
    }
  ],
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "financial_core": {
        "terms": [
          "stock",
          "bond",
          "equity",
          "dividend",
          "investment",
          "portfolio",
          "asset",
          "liability",
          "revenue",
          "profit",
          "loss"
        ],
        "weight": 1.2
      },
      "markets": {
        "terms": [
          "market",
          "exchange",
          "NYSE",
          "NASDAQ",
          "trading",
          "IPO",
          "bull market",
          "bear market",
          "volatility",
          "index"
        ],
        "weight": 1.0
      },
      "metrics": {
        "terms": [
          "P/E ratio",
          "market cap",
          "ROI",
          "EBITDA",
          "EPS",
          "yield",
          "spread",
          "margin",
          "leverage",
          "liquidity"
        ],
        "weight": 1.1
      },
      "instruments": {
        "terms": [
          "derivative",
          "option",
          "futures",
          "swap",
          "hedge fund",
          "mutual fund",
          "ETF",
          "security",
          "treasury",
          "commodity"
        ],
        "weight": 0.9
      },
      "corporate": {
        "terms": [
          "merger",
          "acquisition",
          "IPO",
          "quarterly",
          "annual report",
          "earnings",
          "shareholder",
          "CEO",
          "CFO",
          "board"
        ],
        "weight": 0.9
      },
      "regulation": {
        "terms": [
          "SEC",
          "GAAP",
          "IFRS",
          "compliance",
          "audit",
          "disclosure",
          "fiduciary",
          "regulatory"
        ],
        "weight": 0.8
      }
    },
    "file_extensions": [
      ".pdf"
    ],
    "doc_types": [
      "financial_report",
      "market_analysis",
      "investment_document"
    ],
    "patterns": [
      {
        "regex": "(?i)\\$[\\d,]+\\.?\\d*\\s*(million|billion|trillion|m|b|k)?\\b",
        "weight": 1.4,
        "description": "Dollar amounts"
      },
      {
        "regex": "\\b\\d+(\\.\\d+)?\\s*%\\b",
        "weight": 1.2,
        "description": "Percentage values"
      },
      {
        "regex": "(?i)\\b(q[1-4]|fy|h[12])\\s*['�]?\\d{2,4}\\b",
        "weight": 1.3,
        "description": "Quarter/Fiscal year/Half"
      },
      {
        "regex": "(?i)\\b[A-Z]{1,5}\\b(?=\\s+(stock|shares|equity|common|preferred))",
        "weight": 1.1,
        "description": "Ticker symbols"
      },
      {
        "regex": "(?i)\\b(revenue|earnings|ebitda|profit|loss|margin|growth)\\b",
        "weight": 1.0,
        "description": "Financial metrics"
      }
    ],
    "confidence": {
      "base_score": 0.25,
      "per_keyword_boost": 0.04,
      "extension_boost": 0.1,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- Extract companies, financial instruments, markets, regulators, and investors\n- Include financial metrics as properties, not standalone entities\n- Use full company names with ticker symbols as aliases\n\nDO NOT EXTRACT:\n- Raw numbers alone: '$5M', '15%', 'Q3 2024' (attach to relevant entity as property)\n- Ticker symbols without context: just 'AAPL' (extract the company instead)\n- Boilerplate disclaimers: 'past performance', 'not financial advice'\n- Footnote markers, table headers, or formatting elements",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- TRANSACTIONS: Capture M&A with acquired, investments with invests_in\n- MARKETS: Link instruments to exchanges with trades_on\n- REGULATION: Connect regulators to companies/markets with regulates\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",
  "templates": {
    "node_templates": [
      {
        "@type": "NodeTemplate",
        "id": "fin_template_instrument",
        "name": "Financial Instrument",
        "description": "A stock, bond, derivative, or other financial instrument",
        "icon": "Receipt",
        "color": "#d6417d",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "instruments",
        "normalization_keywords": [
          "stock",
          "bond",
          "security",
          "derivative",
          "share",
          "equity"
        ],
        "properties": [
          {
            "name": "instrument_type",
            "display_name": "Instrument Type",
            "property_type": "text",
            "absorbs_types": [
              "Instrument Type"
            ]
          },
          {
            "name": "maturity",
            "display_name": "Maturity",
            "property_type": "text",
            "absorbs_types": [
              "Maturity"
            ]
          }
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "fin_template_company",
        "name": "Company",
        "description": "A business entity or corporation",
        "icon": "Business",
        "color": "#d64145",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "actors",
        "normalization_keywords": [
          "company",
          "corporation",
          "firm",
          "business",
          "Inc.",
          "Ltd.",
          "Corp."
        ],
        "properties": [
          {
            "name": "ticker",
            "display_name": "Ticker Symbol",
            "property_type": "text",
            "absorbs_types": [
              "Ticker"
            ]
          },
          {
            "name": "sector",
            "display_name": "Sector",
            "property_type": "text"
          },
          {
            "name": "market_cap",
            "display_name": "Market Capitalization",
            "property_type": "text",
            "absorbs_types": [
              "Market Cap"
            ]
          }
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "fin_template_market",
        "name": "Market",
        "description": "A financial market or exchange",
        "icon": "TrendingUp",
        "color": "#d67541",
        "requires_named_referent": true,
        "quality_score": 18,
        "compatibility_group": "markets",
        "normalization_keywords": [

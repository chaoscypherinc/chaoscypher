          "AAPL",
          "Apple Computer"
        ],
        "note": "Ticker symbols and historical names become aliases"
      },
      {
        "canonical": "JPMorgan Chase & Co.",
        "aliases": [
          "JPMorgan",
          "Chase",
          "JPM"
        ],
        "note": "Short names and ticker symbols become aliases"
      }
    ],
    "relationship_examples": [
      {
        "source": "Microsoft",
        "target": "Activision Blizzard",
        "type": "acquired",
        "note": "Use acquired for M&A transactions"
      },
      {
        "source": "Tesla",
        "target": "S&P 500",
        "type": "listed_on",
        "note": "Use listed_on for exchange/index membership"
      }
    ]
  },
  "extraction_limits": {
    "max_entity_degree": 20,
    "max_same_source_type": 8,
    "max_relationship_ratio": 6.0,
    "loop_max_entity_count": 35
  },
  "quality_scoring": {
    "default_entity_score": 18,
    "default_relationship_score": 15
  },
  "title_words": [
    "mr",
    "mrs",
    "ms",

  "examples": {
    "alias_examples": [
      {
        "canonical": "Brown v. Board of Education",
        "aliases": [
          "Brown v. Board",
          "Brown",
          "347 U.S. 483"
        ],
        "note": "Short case names and citations become aliases"
      },
      {
        "canonical": "Americans with Disabilities Act",
        "aliases": [
          "ADA",
          "42 U.S.C. � 12101"
        ],
        "note": "Abbreviations and code citations become aliases"
      }
    ],
    "relationship_examples": [
      {
        "source": "Roe v. Wade",
        "target": "Planned Parenthood v. Casey",
        "type": "cites",
        "note": "Use cites for precedent citation chains"
      },
      {
        "source": "Justice Ginsburg",
        "target": "Shelby County v. Holder",
        "type": "dissents_from",
        "note": "Use dissents_from for judicial dissents"
      }
    ]
  },

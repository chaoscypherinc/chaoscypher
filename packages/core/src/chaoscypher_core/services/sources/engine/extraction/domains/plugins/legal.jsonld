        "icon": "Person",
        "color": "#8e41d6",
        "requires_named_referent": true,
        "quality_score": 18,
        "compatibility_group": "legal_actors",
        "normalization_keywords": [
          "plaintiff",
          "defendant",
          "petitioner",
          "respondent",
          "appellant",
          "appellee",
          "party to"
        ],
        "properties": [
          {
            "name": "role",
            "display_name": "Role",
            "property_type": "text",
            "absorbs_types": [
              "Party Role"
            ]
          }
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "legal_template_jurisdiction",

{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:legal",
  "name": "legal",
  "version": "1.9.0",
  "description": "Legal documents, court cases, statutes, contracts, and regulations",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.25,
  "strict_entity_types": true,
  "entity_exclusions": [
    {
      "description": "Paragraph and section numbers",
      "examples": [
        "Section 3.1",
        "Article II",
        "� 42"
      ]
    },
    {
      "description": "Procedural boilerplate",
      "examples": [
        "hereby",
        "whereas",
        "notwithstanding",
        "witnesseth"
      ]
    },
    {
      "description": "Generic party references",
      "examples": [
        "the plaintiff",
        "the defendant"
      ]
    },
    {
      "description": "Citation formatting",
      "examples": [
        "Id.",
        "supra",
        "infra",
        "op. cit."
      ]
    }
  ],
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "legal_core": {
        "terms": [
          "plaintiff",
          "defendant",
          "court",
          "statute",
          "jurisdiction",
          "precedent",
          "ruling",
          "judgment",
          "verdict",
          "appeal",
          "litigation",
          "lawsuit"
        ],
        "weight": 1.2
      },
      "contract": {
        "terms": [
          "hereby",
          "whereas",
          "party",
          "agreement",
          "liable",
          "covenant",
          "indemnify",
          "warrant",
          "breach",
          "termination",
          "obligation",
          "consideration"
        ],
        "weight": 1.0
      },
      "procedural": {
        "terms": [
          "motion",
          "hearing",
          "filing",
          "discovery",
          "deposition",
          "subpoena",
          "injunction",
          "writ",
          "summons",
          "pleading"
        ],
        "weight": 0.9
      },
      "legal_concepts": {
        "terms": [
          "liability",
          "negligence",
          "damages",
          "tort",
          "remedy",
          "standing",
          "due process",
          "constitutional",
          "rights",
          "duties"
        ],
        "weight": 0.8
      },
      "legal_actors": {
        "terms": [
          "judge",
          "attorney",
          "counsel",
          "prosecutor",
          "lawyer",
          "magistrate",
          "jury",
          "witness",
          "claimant"
        ],
        "weight": 0.8
      },
      "citations": {
        "terms": [
          "v.",
          "vs.",
          "U.S.C.",
          "F.2d",
          "F.3d",
          "S.Ct.",
          "L.Ed.",
          "Cal.",
          "N.Y."
        ],
        "weight": 1.3
      }
    },
    "file_extensions": [
      ".pdf",
      ".docx"
    ],
    "doc_types": [
      "legal_document",
      "court_filing",
      "contract"
    ],
    "patterns": [
      {
        "regex": "\\b[A-Z][a-z]+\\s+v\\.?\\s+[A-Z][a-z]+\\b",
        "weight": 1.5,
        "description": "Case citation pattern"
      },
      {
        "regex": "(?i)\\b\\d+\\s+U\\.?S\\.?C\\.?\\s+\\d+\\b",
        "weight": 1.4,
        "description": "USC citation"
      },
      {
        "regex": "(?i)\\b(whereas|hereby|witnesseth|wherefore|herein|therein|thereof|hereto)\\b",
        "weight": 1.3,
        "description": "Contract/legal language"
      },
      {
        "regex": "(?i)\\b(section|article|paragraph|clause)\\s+\\d+(\\.\\d+)*\\b",
        "weight": 1.0,
        "description": "Section references"
      },
      {
        "regex": "(?i)\\b(plaintiff|defendant|petitioner|respondent)\\b",
        "weight": 1.2,
        "description": "Party designations"
      }
    ],
    "confidence": {
      "base_score": 0.25,
      "per_keyword_boost": 0.05,
      "extension_boost": 0.1,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- Extract statutes, cases, legal doctrines, courts, and named parties\n- Use official case citations and names\n- Include jurisdiction and date in properties\n\nDO NOT EXTRACT:\n- Paragraph/section numbers: � 42, Section 3.1, Article II\n- Procedural boilerplate: 'hereby', 'whereas', 'notwithstanding'\n- Generic references: 'the plaintiff', 'the defendant' (extract named parties instead)\n- Citation formatting: Id., supra, infra, op. cit.",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- PRECEDENT: Capture citation chains with cites, overrules, affirms\n- PARTIES: Extract all named parties with party_to relationship\n- DOCTRINE: Link cases to legal doctrines they establish or apply\n- HIERARCHY: Use adjudicates to connect courts to cases\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",
  "templates": {
    "node_templates": [
      {
        "@type": "NodeTemplate",
        "id": "legal_template_statute",
        "name": "Statute",
        "description": "A law enacted by a legislative body",
        "icon": "MenuBook",
        "color": "#41c7d6",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "legal_documents",
        "normalization_keywords": [
          "a statute",
          "the law",
          "enacted by",
          "legislative act",
          "code section",
          "act of",
          "legislation"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "legal_template_case",
        "name": "Case",
        "description": "A legal case or court decision",
        "icon": "Gavel",
        "color": "#4192d6",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "legal_documents",
        "normalization_keywords": [
          "the case",
          "court held",
          "ruling in",
          "decision in",
          "v.",
          "vs.",
          "matter of"
        ],
        "properties": [
          {
            "name": "date_decided",
            "display_name": "Date Decided",
            "property_type": "date",
            "absorbs_types": [
              "Decision Date"
            ]
          },
          {
            "name": "jurisdiction",
            "display_name": "Jurisdiction",
            "property_type": "text"
          },
          {
            "name": "citation",
            "display_name": "Citation",
            "property_type": "text",
            "absorbs_types": [
              "Citation"
            ]
          }
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "legal_template_doctrine",
        "name": "Legal Doctrine",
        "description": "An established legal principle or rule",
        "icon": "Lightbulb",
        "color": "#415ed6",
        "requires_named_referent": false,
        "quality_score": 25,
        "compatibility_group": "legal_concepts",
        "normalization_keywords": [
          "doctrine",
          "legal principle",
          "rule that",
          "established that",
          "holding that"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "legal_template_court",
        "name": "Court",
        "description": "A judicial body or tribunal",
        "icon": "AccountBalance",
        "color": "#5941d6",
        "requires_named_referent": true,
        "quality_score": 18,
        "compatibility_group": "legal_actors",
        "normalization_keywords": [

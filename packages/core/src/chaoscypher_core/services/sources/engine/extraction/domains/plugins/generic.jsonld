{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:generic",
  "name": "generic",
  "version": "1.9.0",
  "description": "General-purpose domain for any content that does not match a specialized domain. Flexible entity and relationship types adapt to the source material.",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.0,
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {},
    "file_extensions": [],
    "doc_types": [],
    "patterns": [],
    "confidence": {
      "base_score": 0.1,
      "per_keyword_boost": 0.0,
      "extension_boost": 0.0,
      "doc_type_boost": 0.0,
      "pattern_boost": 0.0,
      "max_confidence": 0.1,
      "min_threshold": 0.0
    }
  },
  "entity_exclusions": [
    {
      "description": "Pronouns and vague references",
      "examples": [
        "he",
        "she",
        "they",
        "it",
        "someone"
      ]
    },
    {
      "description": "Single common words without specific meaning",
      "examples": [
        "the thing",
        "the item"
      ]
    }
  ],
  "entity_guidance": "EXTRACTION RULES:\n- Extract ALL named entities: people, organizations, places, events, concepts, works\n- Use the most specific entity type available from the templates below\n- Include rich properties: titles, roles, dates, status, descriptions\n- ALIASES: Include alternative names, abbreviations, titles, nicknames\n- PROPERTIES: Extract ALL relevant attributes mentioned in text\n\nDO NOT EXTRACT:\n- Pronouns or vague references: he, she, they, it\n- Structural markers: page numbers, headers, footers\n- Boilerplate: copyright notices, watermarks\n- Common words without specific meaning",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- Prefer specific relationship types over generic 'related_to' or 'link'\n- Include justification for each relationship\n- HIERARCHY: Use part_of/contains for compositional relationships\n- PEOPLE: Use works_at, collaborates_with, reports_to for professional ties\n- TEMPORAL: Use preceded_by, followed_by for sequences\n- CAUSAL: Use causes, enables, prevents for cause-effect chains\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",
  "templates": {
    "node_templates": [
      {
        "@type": "NodeTemplate",
        "id": "gen_template_person",
        "name": "Person",
        "description": "An individual human being",
        "icon": "Person",
        "color": "#7d41d6",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "actors",
        "normalization_keywords": [
          "person",
          "individual",
          "someone named",
          "a man",
          "a woman",
          "he",
          "she"
        ],
        "properties": [
          {
            "name": "title",
            "display_name": "Title/Role",
            "property_type": "text",
            "absorbs_types": [
              "Title",
              "Role"
            ]
          },
          {
            "name": "occupation",
            "display_name": "Occupation",
            "property_type": "text",
            "absorbs_types": [
              "Occupation",
              "Profession"
            ]
          },
          {
            "name": "affiliation",
            "display_name": "Affiliation",
            "property_type": "text",
            "absorbs_types": [
              "Affiliation"
            ]
          }
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "gen_template_organization",
        "name": "Organization",
        "description": "A company, institution, group, government body, or collective entity",
        "icon": "Business",
        "color": "#bc41d6",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "actors",
        "normalization_keywords": [
          "company",
          "organization",
          "institution",
          "agency",
          "group",
          "corporation",
          "firm",
          "association",
          "foundation"
        ],
        "properties": [
          {
            "name": "org_type",
            "display_name": "Type",
            "property_type": "text",
            "absorbs_types": [
              "Organization Type"
            ]
          },
          {
            "name": "industry",
            "display_name": "Industry/Sector",
            "property_type": "text",
            "absorbs_types": [
              "Industry",
              "Sector"
            ]
          }
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "gen_template_location",
        "name": "Location",
        "description": "A place, city, country, region, or geographical area",
        "icon": "Place",
        "color": "#d641b0",
        "requires_named_referent": true,
        "quality_score": 18,
        "compatibility_group": "places",
        "normalization_keywords": [
          "place",
          "city",
          "country",
          "region",
          "area",
          "location",
          "site",
          "territory"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "gen_template_event",
        "name": "Event",
        "description": "A significant occurrence, incident, or milestone",
        "icon": "Event",
        "color": "#d64170",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "events",
        "normalization_keywords": [
          "event",
          "occurred",
          "happened",
          "took place",
          "incident",
          "milestone"
        ],
        "properties": [
          {
            "name": "date",
            "display_name": "Date",
            "property_type": "date",
            "absorbs_types": [
              "Event Date",
              "Date"
            ]
          },
          {
            "name": "event_type",
            "display_name": "Type",
            "property_type": "text",
            "absorbs_types": [
              "Event Type"
            ]
          }
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "gen_template_concept",
        "name": "Concept",
        "description": "An idea, theory, principle, or abstract notion",
        "icon": "Lightbulb",
        "color": "#d65241",
        "requires_named_referent": false,
        "quality_score": 18,
        "compatibility_group": "ideas",
        "normalization_keywords": [

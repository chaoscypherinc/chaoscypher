      },
      "supply_chain": {
        "terms": [
          "supply chain",
          "dependency",
          "software bill of materials",
          "SBOM",
          "third-party risk",
          "vendor risk",
          "package manager",
          "typosquatting",
          "dependency confusion",
          "trusted supplier"
        ],
        "weight": 1.0
      },
      "cloud_security": {
        "terms": [
          "cloud security",
          "IAM",
          "S3 bucket",
          "Azure AD",
          "container escape",
          "Kubernetes",
          "serverless",
          "cloud misconfiguration",
          "CSPM",
          "CWPP",
          "CNAPP"

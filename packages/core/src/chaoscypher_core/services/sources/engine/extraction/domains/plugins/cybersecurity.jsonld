          "patching",
          "hardening",
          "sandboxing",
          "WAF",
          "zero trust",
          "microsegmentation",
          "deception technology",
          "honeypot"
        ],
        "weight": 1.0
      },
      "actors": {
        "terms": [
          "threat actor",
          "APT",
          "nation-state",
          "hacktivist",
          "cybercriminal",
          "insider threat",
          "adversary",
          "attacker",
          "red team",
          "blue team",
          "initial access broker",
          "RaaS operator",
          "ransomware affiliate",
          "intrusion set"
        ],

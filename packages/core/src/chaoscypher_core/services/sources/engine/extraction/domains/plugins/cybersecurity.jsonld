{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:cybersecurity",
  "name": "cybersecurity",
  "version": "1.9.0",
  "description": "Cybersecurity, threat intelligence, vulnerability research, incident response, and information security",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.2,
  "strict_entity_types": true,
  "type_aliases": {
    "APT Group": "Threat Actor",
    "Adversary": "Threat Actor",
    "Backdoor": "Malware",
    "RAT": "Malware"
  },
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "threats": {
        "terms": [
          "malware",
          "ransomware",
          "phishing",
          "trojan",
          "worm",
          "rootkit",
          "backdoor",
          "exploit",
          "zero-day",
          "payload",
          "command and control",
          "C2",
          "botnet",
          "RAT",
          "supply chain attack",
          "LOLBin",
          "fileless",
          "credential stuffing",
          "watering hole",
          "spear phishing",
          "living off the land"
        ],
        "weight": 1.3
      },
      "vulnerabilities": {
        "terms": [
          "vulnerability",
          "CVE",
          "exploit",
          "buffer overflow",
          "injection",
          "cross-site scripting",
          "XSS",
          "SQL injection",
          "remote code execution",
          "RCE",
          "privilege escalation",
          "zero-day"

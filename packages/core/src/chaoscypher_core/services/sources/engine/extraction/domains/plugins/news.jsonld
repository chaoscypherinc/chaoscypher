{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:news",
  "name": "news",
  "version": "1.13.0",
  "description": "News articles, journalism, press releases, and current events",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 0.95,
  "strict_entity_types": true,
  "type_aliases": {
    "Suspect": "Person",
    "Victim": "Person",
    "Stakeholder": "Person"
  },
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "news_core": {
        "terms": [
          "breaking news",
          "developing story",
          "sources say",
          "according to a source",
          "wire service",
          "press conference",
          "according to officials",
          "according to authorities",
          "according to the report"
        ],
        "weight": 1.2
      },
      "journalism": {
        "terms": [
          "journalist",
          "reporter",
          "correspondent",
          "newsroom",
          "newspaper",
          "wire service",
          "Associated Press",
          "Reuters",
          "AFP",
          "told reporters",
          "spokesperson said",
          "spokesman said",
          "spokeswoman said"
        ],
        "weight": 1.0
      },
      "attribution": {
        "terms": [
          "officials said",
          "authorities said",
          "the agency said",
          "in a statement",
          "issued a statement",
          "police said",
          "the spokesperson",
          "responding to questions",
          "no comment",
          "declined to comment"
        ],
        "weight": 0.9
      },
      "structure": {
        "terms": [
          "headline",
          "dateline",
          "byline",
          "press release",
          "lede"
        ],
        "weight": 1.0
      },
      "time_markers": {
        "terms": [
          "last week",
          "this morning",
          "earlier today",
          "on Monday",
          "on Tuesday",
          "on Wednesday",
          "on Thursday",
          "on Friday"
        ],
        "weight": 0.7
      },
      "disaster_response": {
        "terms": [
          "evacuated",
          "first responders",
          "emergency services",
          "death toll",
          "displaced",
          "casualties",
          "search and rescue",
          "state of emergency",
          "in response to the"
        ],
        "weight": 1.0
      }
    },
    "file_extensions": [],
    "doc_types": [
      "news_article",
      "press_release",
      "journalism"
    ],
    "patterns": [
      {
        "regex": "\\b[A-Z]{2,}\\s*[-–—]\\s*",
        "weight": 1.3,
        "description": "Dateline pattern (CITY -)"
      },
      {
        "regex": "(?i)\\baccording\\s+to\\s+[A-Z]",
        "weight": 1.2,
        "description": "Source attribution"
      },
      {
        "regex": "(?i)\\b(monday|tuesday|wednesday|thursday|friday|saturday|sunday)\\b",
        "weight": 0.8,
        "description": "Day references"
      },
      {
        "regex": "(?i)\\b\\d{1,2}:\\d{2}\\s*(am|pm|a\\.?m\\.?|p\\.?m\\.?)?\\b",
        "weight": 0.9,
        "description": "Time stamps"
      },
      {
        "regex": "(?i)\\b(breaking|exclusive|update|developing|just\\s+in)\\b",
        "weight": 1.1,
        "description": "News urgency markers"
      },
      {
        "regex": "(?i)\\b(reuters|associated\\s+press|ap|afp)\\b",
        "weight": 1.4,
        "description": "Wire service attribution"
      },
      {
        "regex": "(?i)\\b(monday|tuesday|wednesday|thursday|friday|saturday|sunday)\\s*,\\s*(january|february|march|april|may|june|july|august|september|october|november|december)\\s+\\d{1,2},?\\s+\\d{4}",
        "weight": 1.8,
        "description": "Wikinews-style dateline (Day, Month DD, YYYY)"
      },
      {
        "regex": "(?i)\\b(killed|injured|wounded|displaced)\\s+(at\\s+least\\s+)?[\\d,]+",
        "weight": 1.5,
        "description": "Casualty count language"
      },
      {
        "regex": "\\b(USA Today|New York Times|Washington Post|BBC|CNN|Globe and Mail|TVNZ|NHK|Al Jazeera|Bloomberg|The Guardian)\\b",
        "weight": 1.3,
        "description": "Named news outlets"
      }
    ],
    "confidence": {
      "base_score": 0.25,
      "per_keyword_boost": 0.04,
      "extension_boost": 0.0,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_exclusions": [
    {
      "description": "Wire service boilerplate",
      "examples": [
        "CITY (AP) -"
      ]
    },
    {
      "description": "Vague attributions",
      "examples": [
        "sources say",
        "officials said"
      ]
    },
    {
      "description": "Editorial markers",
      "examples": [
        "breaking",
        "developing",
        "update",
        "exclusive"
      ]
    }
  ],
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- Extract news events, people, organizations, locations, and sources\n- Capture both named and anonymous sources as Source entities\n- Include dates and locations in properties\n\nDO NOT EXTRACT:\n- Wire service boilerplate: 'CITY (AP) -', bylines, datelines as entities\n- Vague attributions: 'sources say', 'officials said' (without specificity)\n- Editorial markers: 'breaking', 'developing', 'update'\n- Social media handles: @username (unless the person is the focus)",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- ATTRIBUTION: Link quotes to speakers with quoted_as_saying\n- EVENTS: Connect people/organizations to events with involves\n- TIMELINE: Use occurred_at to link events to dates/times\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",
  "templates": {
    "node_templates": [
      {
        "@type": "NodeTemplate",
        "id": "news_template_event",
        "name": "News Event",
        "description": "A newsworthy event or occurrence",
        "icon": "Newspaper",
        "color": "#41d6a5",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "events",
        "normalization_keywords": [
          "event",
          "incident",
          "occurred",
          "happened",
          "took place",
          "breaking",
          "developing"
        ],
        "properties": [
          {
            "name": "date",
            "display_name": "Date",
            "property_type": "date",
            "absorbs_types": [
              "Event Date"
            ]
          },
          {
            "name": "severity",
            "display_name": "Severity",
            "property_type": "text",
            "absorbs_types": [
              "Severity"
            ]
          }
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "news_template_person",
        "name": "Person",
        "description": "A person mentioned in the news",
        "icon": "Person",
        "color": "#41d0d6",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "people",
        "normalization_keywords": [
          "person",
          "individual",
          "official",
          "spokesperson",
          "witness"
        ],
        "properties": [
          {
            "name": "title",
            "display_name": "Title",
            "property_type": "text",
            "absorbs_types": [
              "Title"
            ]
          },
          {
            "name": "organization",
            "display_name": "Organization",
            "property_type": "text",
            "absorbs_types": [
              "Affiliation"
            ]
          },
          {
            "name": "role",
            "display_name": "Role",
            "property_type": "text",
            "absorbs_types": [
              "Role"
            ]
          }
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "news_template_org",
        "name": "Organization",
        "description": "A company, government, or group",
        "icon": "Business",
        "color": "#4198d6",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "people",
        "normalization_keywords": [
          "company",
          "organization",
          "government",
          "agency",
          "group",
          "corporation"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "news_template_quote",
        "name": "Quote",
        "description": "A direct quotation from a source",
        "icon": "FormatQuote",
        "color": "#4160d6",
        "requires_named_referent": false,
        "quality_score": 18,
        "compatibility_group": "media",
        "normalization_keywords": [
          "quote",
          "said",
          "stated",
          "commented",
          "remarked"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "news_template_source",
        "name": "Source",
        "description": "An information source (named or anonymous)",
        "icon": "ContactPhone",
        "color": "#5b41d6",
        "requires_named_referent": true,
        "quality_score": 18,
        "compatibility_group": "people",
        "normalization_keywords": [
          "source",
          "according to",
          "reported by",
          "confirmed by",
          "official said"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "news_template_location",

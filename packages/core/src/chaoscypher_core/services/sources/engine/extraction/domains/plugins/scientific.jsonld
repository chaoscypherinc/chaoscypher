      },
      {
        "@type": "NodeTemplate",
        "id": "sci_template_chemical",
        "name": "Chemical",
        "description": "A chemical element or simple substance (e.g. ``carbon``, ``hydrogen``, ``sodium chloride``)",
        "icon": "Science",
        "color": "#cc41d6",
        "requires_named_referent": true,
        "quality_score": 18,
        "compatibility_group": "research_elements",
        "normalization_keywords": [
          "chemical",

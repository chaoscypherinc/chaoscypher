  "quality_scoring": {
    "default_entity_score": 18,
    "default_relationship_score": 15
  },
  "examples": {
    "alias_examples": [
      {
        "canonical": "CRISPR-Cas9",
        "aliases": [
          "CRISPR",
          "Cas9 system",
          "gene editing tool"
        ],
        "note": "Abbreviations and common names become aliases"
      },
      {
        "canonical": "Polymerase Chain Reaction",
        "aliases": [
          "PCR",
          "RT-PCR"
        ],
        "note": "Acronyms and variants become aliases"
      }
    ],
    "relationship_examples": [
      {
        "source": "Experiment A",
        "target": "Hypothesis 1",
        "type": "tests",
        "note": "Use tests for experiment-hypothesis links"
      },
      {
        "source": "Finding X",
        "target": "Theory Y",
        "type": "supports",
        "note": "Use supports when evidence backs a theory"
      }
    ]
  },
  "title_words": [
    "mr",
    "mrs",
    "ms",
    "miss",
    "dr",
    "sir",
    "dame",
    "madam",
    "the",
    "of",
    "de",
    "von",
    "van",
    "professor"
  ],
  "extraction_limits": {
    "max_entity_degree": 20,
    "max_same_source_type": 8,
    "max_relationship_ratio": 6.0,
    "loop_max_entity_count": 40
  },
  "content_exclusions": {
    "categories": [
      "toc",
      "legal",
      "boilerplate",
      "acknowledgments",
      "metadata",
      "web_artifacts",
      "procedural"
    ]
  },
  "extraction_filtering_mode": "strict",
  "icon": "Science"
}

          "substance",
          "reagent"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "sci_template_compound",
        "name": "Compound",
        "description": "A chemical compound or molecule — a defined combination of elements (e.g. ``H2SO4``, ``glucose``, ``ATP``)",
        "icon": "Hub",
        "color": "#d641c5",
        "requires_named_referent": true,
        "quality_score": 18,
        "compatibility_group": "research_elements",
        "normalization_keywords": [
          "compound",
          "molecule",
          "salt",
          "polymer"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "sci_template_equipment",
        "name": "Equipment",
        "description": "General scientific equipment or apparatus — a fixture or assembly used during research (centrifuge, fume hood, bench)",
        "icon": "Construction",
        "color": "#d641ac",
        "requires_named_referent": true,
        "quality_score": 15,
        "compatibility_group": "methodology",
        "normalization_keywords": [
          "equipment",

          "computational model",
          "simulation",
          "framework"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "sci_template_researcher",
        "name": "Researcher",
        "description": "A scientist, author, or research team",
        "icon": "Person",
        "color": "#41bed6",
        "requires_named_referent": true,
        "quality_score": 18,
        "compatibility_group": "people_places",
        "normalization_keywords": [

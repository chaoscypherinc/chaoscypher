{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:scientific",
  "name": "scientific",
  "version": "1.9.0",
  "description": "Scientific research papers, studies, experiments, and academic publications",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.3,
  "strict_entity_types": true,
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "research_core": {
        "terms": [
          "hypothesis",
          "experiment",
          "methodology",
          "results",
          "conclusion",
          "abstract",
          "study",
          "research",
          "investigation",
          "analysis",
          "findings"
        ],
        "weight": 1.2
      },
      "statistics": {
        "terms": [
          "p-value",
          "significance",
          "correlation",
          "regression",
          "sample size",
          "confidence interval",
          "standard deviation",
          "variance",
          "null hypothesis",
          "statistical",
          "mean",
          "median"
        ],
        "weight": 1.0
      },
      "scientific_method": {
        "terms": [
          "control group",
          "experimental group",
          "variable",
          "independent variable",
          "dependent variable",
          "randomized",
          "double-blind",
          "placebo",
          "replication",
          "peer-reviewed"
        ],
        "weight": 1.0
      },
      "publication": {
        "terms": [
          "journal",
          "citation",
          "DOI",
          "peer-reviewed",
          "published",
          "authors",
          "references",
          "bibliography",
          "supplementary",
          "appendix"
        ],
        "weight": 0.8
      },
      "disciplines": {
        "terms": [
          "biology",
          "chemistry",
          "physics",
          "neuroscience",
          "psychology",
          "ecology",
          "genetics",
          "biochemistry",
          "molecular",
          "cellular",
          "computational"
        ],
        "weight": 0.6
      },
      "data_terms": {
        "terms": [
          "dataset",
          "data collection",
          "measurements",
          "observations",
          "quantitative",
          "qualitative",
          "empirical",
          "protocol",
          "procedure"
        ],
        "weight": 0.8
      },
      "physics_concepts": {
        "terms": [
          "electron",
          "proton",
          "neutron",
          "photon",
          "quantum",
          "electromagnetic",
          "wavelength",
          "frequency",
          "nucleus",
          "orbital",
          "subatomic",
          "thermodynamic",
          "kinetic energy",
          "potential energy",
          "gravitational",
          "magnetic field",
          "electric field",
          "radioactive",
          "superconductor",
          "relativity",
          "wave function",
          "atomic number",
          "atomic mass",
          "elementary particle"
        ],
        "weight": 1.0
      },
      "chemistry_concepts": {
        "terms": [
          "chemical bond",
          "compound",
          "isotope",
          "valence",
          "periodic table",
          "catalyst",
          "oxidation",
          "covalent",
          "ionic bond",
          "stoichiometry",
          "molar mass",
          "chemical reaction",
          "molecular structure"
        ],
        "weight": 0.9
      },
      "biology_concepts": {
        "terms": [
          "DNA",
          "RNA",
          "genome",
          "chromosome",
          "enzyme",
          "photosynthesis",
          "mitosis",
          "natural selection",
          "ecosystem",
          "metabolism",
          "ribosome",
          "organelle",
          "cell membrane"
        ],
        "weight": 0.8
      }
    },
    "file_extensions": [
      ".pdf"
    ],
    "doc_types": [
      "academic_paper",
      "research_article",
      "scientific_publication"
    ],
    "patterns": [
      {
        "regex": "(?i)\\b(p\\s*[<>=]\\s*0\\.\\d+)\\b",
        "weight": 1.5,
        "description": "P-value notation"
      },
      {
        "regex": "(?i)\\b(n\\s*=\\s*\\d+)\\b",
        "weight": 1.3,
        "description": "Sample size notation"
      },
      {
        "regex": "(?i)\\b(et\\s+al\\.?)\\b",
        "weight": 1.2,
        "description": "Citation pattern"
      },
      {
        "regex": "(?i)\\b(doi:|DOI:)\\s*10\\.\\d+",
        "weight": 1.4,
        "description": "DOI pattern"
      },
      {
        "regex": "(?i)\\b(figure|fig\\.|table)\\s+\\d+",
        "weight": 1.0,
        "description": "Figure/Table references"
      },
      {
        "regex": "(?i)\\b(abstract|methods|results|discussion|conclusion|references|introduction)\\s*:",
        "weight": 1.3,
        "description": "Paper section headers"
      },
      {
        "regex": "\\d+\\.?\\d*\\s*[×x]\\s*10",
        "weight": 1.3,
        "description": "Scientific notation"
      },
      {
        "regex": "(?i)\\b\\d+\\.?\\d*\\s*(eV|keV|MeV|GeV|nm|pm|amu|Hz|GHz|MHz|m/s|km/s)\\b",
        "weight": 1.2,
        "description": "Physics units"
      }
    ],
    "confidence": {
      "base_score": 0.25,
      "per_keyword_boost": 0.04,
      "extension_boost": 0.1,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_exclusions": [
    {
      "description": "Figure and table references",
      "examples": [
        "Figure 1",
        "Table S2",
        "Supplementary Figure S3"
      ]
    },
    {
      "description": "Statistical notation as entities",
      "examples": [
        "p < 0.05",
        "n = 100",
        "CI 95%"
      ]
    },
    {
      "description": "Generic labels",
      "examples": [
        "this study",
        "the results",
        "our findings",
        "the data"
      ]
    },
    {
      "description": "Citation markers",
      "examples": [
        "[1]",
        "(Smith et al., 2020)",
        "et al."
      ]
    }
  ],
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- Extract hypotheses, experiments, findings, researchers, and publications\n- Include specific study names, methodology descriptions\n- Extract variables (independent, dependent, controlled)\n\nDO NOT EXTRACT:\n- Figure/table references: Figure 1, Table 2, Supplementary Figure S3\n- Statistical notation as entities: p < 0.05, n = 100, CI 95%\n- Generic labels: 'this study', 'our results', 'the data'\n- Page numbers, DOIs, or formatting markers",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- HYPOTHESIS-EVIDENCE: Link findings to hypotheses with supports/contradicts\n- METHODOLOGY: Capture methods and link experiments with uses_method\n- CITATIONS: Extract cites relationships between publications\n- VARIABLES: Identify independent/dependent variables with measures relationship\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",
  "templates": {
    "node_templates": [
      {
        "@type": "NodeTemplate",
        "id": "sci_template_hypothesis",
        "name": "Hypothesis",
        "description": "A testable prediction or theoretical claim",
        "icon": "Lightbulb",
        "color": "#d67441",
        "requires_named_referent": false,
        "quality_score": 25,
        "compatibility_group": "research_elements",
        "normalization_keywords": [
          "a hypothesis",
          "we hypothesize",
          "predicts that",
          "proposed that",
          "hypothesized",
          "prediction that"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "sci_template_experiment",
        "name": "Experiment",
        "description": "A scientific study, trial, or investigation",
        "icon": "Science",
        "color": "#d6a941",
        "requires_named_referent": false,
        "quality_score": 25,
        "compatibility_group": "methodology",
        "normalization_keywords": [
          "an experiment",
          "study design",
          "we conducted",
          "trial of",
          "investigation of",
          "experimental study"
        ],
        "properties": [
          {
            "name": "sample_size",
            "display_name": "Sample Size",
            "property_type": "text",
            "absorbs_types": [
              "Sample Size"
            ]
          },
          {
            "name": "duration",
            "display_name": "Duration",
            "property_type": "text",
            "absorbs_types": [
              "Duration"
            ]
          }
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "sci_template_method",
        "name": "Method",
        "description": "A research methodology, technique, or protocol",
        "icon": "Build",
        "color": "#cfd641",
        "requires_named_referent": false,
        "quality_score": 18,
        "compatibility_group": "methodology",
        "normalization_keywords": [
          "methodology",
          "procedure",
          "protocol",
          "technique used",
          "method of",
          "approach"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "sci_template_finding",
        "name": "Finding",
        "description": "A research result, observation, or discovery",
        "icon": "Insights",
        "color": "#9bd641",
        "requires_named_referent": false,
        "quality_score": 25,
        "compatibility_group": "research_elements",
        "normalization_keywords": [
          "finding",
          "result shows",
          "we found",
          "data indicates",
          "observation",
          "discovered that",
          "results demonstrate"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "sci_template_dataset",
        "name": "Dataset",
        "description": "A collection of data used or produced in research",
        "icon": "Storage",
        "color": "#66d641",
        "requires_named_referent": true,
        "quality_score": 18,
        "compatibility_group": "methodology",
        "normalization_keywords": [
          "dataset",
          "data collected",
          "sample of",
          "corpus of",
          "collection of measurements"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "sci_template_variable",
        "name": "Variable",
        "description": "An independent, dependent, or control variable",
        "icon": "Tune",
        "color": "#41d651",
        "requires_named_referent": false,
        "quality_score": 18,
        "compatibility_group": "methodology",
        "normalization_keywords": [
          "variable",
          "factor",
          "measured",
          "controlled for",
          "independent variable",
          "dependent variable"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "sci_template_theory",
        "name": "Theory",
        "description": "A well-substantiated scientific explanation",
        "icon": "AutoAwesome",
        "color": "#41d686",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "research_elements",
        "normalization_keywords": [
          "theory of",
          "theoretical framework",
          "model predicts",
          "explains that"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "sci_template_model",
        "name": "Model",
        "description": "A mathematical or conceptual representation",
        "icon": "Hub",
        "color": "#41d6ba",
        "requires_named_referent": true,
        "quality_score": 18,
        "compatibility_group": "research_elements",
        "normalization_keywords": [

        ],
        "properties": [
          {
            "name": "affiliation",
            "display_name": "Affiliation",
            "property_type": "text",
            "absorbs_types": [
              "Affiliation"
            ]
          },
          {
            "name": "specialization",
            "display_name": "Specialization",
            "property_type": "text",
            "absorbs_types": [
              "Specialization"
            ]
          }
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "sci_template_publication",
        "name": "Publication",
        "description": "A scientific paper, article, or preprint",
        "icon": "Article",
        "color": "#4189d6",
        "requires_named_referent": true,
        "quality_score": 18,
        "compatibility_group": "publications",
        "normalization_keywords": [
          "paper",
          "article",
          "study",
          "publication",
          "preprint"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "sci_template_field",
        "name": "Field",

        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "sci_template_metric",
        "name": "Metric",
        "description": "A defined quantitative metric — the named thing being measured (e.g. ``signal-to-noise ratio``, ``Q-value``)",
        "icon": "Speed",
        "color": "#d64143",
        "requires_named_referent": false,
        "quality_score": 15,
        "compatibility_group": "methodology",
        "normalization_keywords": [

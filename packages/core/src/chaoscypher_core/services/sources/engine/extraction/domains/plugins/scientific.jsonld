      },
      {
        "@type": "EdgeTemplate",
        "id": "sci_edge_proposes",
        "name": "proposes",
        "description": "Researcher, publication, experiment, or institution proposes a hypothesis, theory, model, method, equation, or formula",
        "icon": "Lightbulb",
        "color": "#cc3a32",

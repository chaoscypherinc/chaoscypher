{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:investigation",
  "name": "investigation",
  "version": "1.9.0",
  "description": "Criminal and civil investigations: case files, evidence, witness statements, forensic reports, legal filings, crime scene documentation, and financial records",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.3,
  "strict_entity_types": true,
  "type_aliases": {
    "Suspect": "Person",
    "Victim": "Person",
    "Witness": "Person"
  },
  "entity_exclusions": [
    {
      "description": "Generic role references without names",
      "examples": [
        "the officer",
        "a detective",
        "the victim",
        "the suspect"
      ]
    },
    {
      "description": "Form instructions",
      "examples": [
        "check one",
        "sign below",
        "see reverse",
        "circle applicable"
      ]
    }
  ],
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "investigation_core": {
        "terms": [
          "investigation",
          "case",
          "suspect",
          "victim",
          "evidence",
          "crime",
          "offense",
          "incident",
          "perpetrator",
          "motive",
          "alibi",
          "accomplice",
          "conspiracy"
        ],
        "weight": 1.3
      },
      "law_enforcement": {
        "terms": [
          "detective",
          "officer",
          "arrest",
          "warrant",
          "booking",
          "Miranda",
          "custody",
          "patrol",
          "precinct",
          "badge",
          "dispatch",
          "apprehend",
          "pursuit",
          "felony",
          "misdemeanor"
        ],
        "weight": 1.2
      },
      "forensics": {
        "terms": [
          "forensic",
          "autopsy",
          "ballistics",
          "toxicology",
          "DNA",
          "fingerprint",
          "lab results",
          "blood spatter",
          "trace evidence",
          "cause of death",
          "manner of death",
          "pathologist",
          "coroner",
          "medical examiner",
          "latent print"
        ],
        "weight": 1.2
      },
      "legal_proceedings": {
        "terms": [
          "indictment",
          "arraignment",
          "bail",
          "plea",
          "prosecution",
          "defense counsel",
          "grand jury",
          "probable cause",
          "beyond reasonable doubt",
          "sentencing",
          "conviction",
          "acquittal",
          "mistrial"
        ],
        "weight": 1.0
      },
      "evidence_handling": {
        "terms": [
          "chain of custody",
          "evidence tag",
          "exhibit",
          "seized",
          "collected",
          "impounded",
          "bagged",
          "logged",
          "evidence room",
          "property receipt",
          "inventory"
        ],
        "weight": 1.1
      },
      "crime_scene": {
        "terms": [
          "crime scene",
          "scene of crime",
          "perimeter",
          "tape",
          "processed",
          "photographed",
          "canvass",
          "point of entry",
          "blood evidence",
          "shell casing",
          "scene reconstruction"
        ],
        "weight": 1.1
      },
      "witness": {
        "terms": [
          "witness",
          "statement",
          "deposition",
          "testimony",
          "interview",
          "corroborate",
          "alibi",
          "eyewitness",
          "sworn",
          "affidavit",
          "recant",
          "identification",
          "lineup"
        ],
        "weight": 1.0
      },
      "financial_crime": {
        "terms": [
          "fraud",
          "embezzlement",
          "money laundering",
          "wire transfer",
          "shell company",
          "forfeiture",
          "asset seizure",
          "illicit funds",
          "kickback",
          "bribery",
          "tax evasion"
        ],
        "weight": 0.9
      },
      "communications": {
        "terms": [
          "wiretap",
          "intercept",
          "phone records",
          "call log",
          "text message",
          "surveillance",
          "recorded conversation",
          "email correspondence",
          "subpoenaed records"
        ],
        "weight": 0.8
      }
    },
    "file_extensions": [
      ".pdf",
      ".docx",
      ".txt"
    ],
    "doc_types": [
      "case_file",
      "police_report",
      "forensic_report",
      "legal_filing",
      "evidence_log",
      "witness_statement"
    ],
    "patterns": [
      {
        "regex": "(?i)\\bCase\\s*(?:No|#|Number)[.:)?\\s]*\\d+",
        "weight": 1.6,
        "description": "Case number references"
      },
      {
        "regex": "(?i)\\b(?:exhibit|item)\\s+[A-Z0-9\\-]+\\b",
        "weight": 1.4,
        "description": "Evidence exhibit markers"
      },
      {
        "regex": "\\b\\d{1,2}/\\d{1,2}/\\d{2,4}\\s+\\d{1,2}:\\d{2}\\b",
        "weight": 1.0,
        "description": "Date-time stamps in reports"
      },
      {
        "regex": "(?i)\\b(?:victim|suspect|witness)\\s*#?\\d+\\b",
        "weight": 1.3,
        "description": "Numbered victim/suspect/witness"
      },
      {
        "regex": "(?i)\\b(?:incident|report|DR)\\s*(?:No|#)?[.:)?\\s]*\\d+",
        "weight": 1.5,
        "description": "Incident/report numbers"
      },
      {
        "regex": "(?i)\\b(?:sworn|under\\s+oath|under\\s+penalty\\s+of\\s+perjury)\\b",
        "weight": 1.2,
        "description": "Sworn statement markers"
      },
      {
        "regex": "(?i)\\b(?:homicide|robbery|assault|burglary|arson|kidnapping|manslaughter|battery)\\b",
        "weight": 1.3,
        "description": "Crime type references"
      },
      {
        "regex": "(?i)\\bDocket\\s*(?:No|#)?[.:)?\\s]*[A-Z0-9\\-]+",
        "weight": 1.4,
        "description": "Docket number references"
      }
    ],
    "confidence": {
      "base_score": 0.25,
      "per_keyword_boost": 0.04,
      "extension_boost": 0.1,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- Extract named people with their investigative role (suspect, victim, witness, investigator, expert) as a property\n- Extract evidence items with IDs/tags when available\n- Extract events with dates and locations\n- Extract crime scenes as distinct from general locations\n- Extract forensic findings with report type and conclusions\n- Extract legal filings with case/docket numbers\n\nDO NOT EXTRACT:\n- Generic role references without names: 'the officer', 'a detective', 'the victim'\n- Report boilerplate: headers, footers, page numbers, form field labels\n- Procedural timestamps: log entries, dispatch times (unless part of a key event)\n- Form instructions: 'check one', 'sign below', 'see reverse'",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- PEOPLE-EVENTS: Use involved_in for general participation, witnessed for eyewitness, investigated for investigators, arrested_for for arrests\n- PEOPLE-EVIDENCE: Use linked_to_evidence for any person-evidence connection, collected for who gathered it, authored for report writers\n- EVIDENCE-LOCATIONS: Use found_at for where evidence was recovered, occurred_at for event locations\n- EVIDENCE-EVIDENCE: Use corroborates when evidence supports other evidence, contradicts when it conflicts, resulted_in for evidence producing reports\n- LEGAL: Use charged_with for charges against people, filed_against for legal filings, authorizes for warrants authorizing searches\n- COMMUNICATIONS: Use sent/received for message authorship and recipients\n- FINANCIAL: Use financial_link for person-to-record, transacted_with for person-to-person financial connections\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",
  "templates": {
    "node_templates": [
      {
        "@type": "NodeTemplate",
        "id": "inv_template_person",
        "name": "Person",
        "description": "A person involved in the investigation in any role",
        "icon": "Person",
        "color": "#41d688",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "people",
        "normalization_keywords": [
          "person",
          "individual",
          "suspect",
          "victim",
          "witness",
          "detective",
          "officer",
          "agent",
          "investigator",
          "defendant",
          "plaintiff",
          "informant",
          "accomplice"
        ],
        "properties": [
          {
            "name": "role",
            "display_name": "Role",
            "property_type": "text",
            "absorbs_types": [
              "Role",
              "Investigative Role",
              "Party Role"
            ]
          },
          {
            "name": "alias",
            "display_name": "Alias",
            "property_type": "text",
            "absorbs_types": [
              "Alias",
              "Known As"
            ]
          },
          {
            "name": "date_of_birth",

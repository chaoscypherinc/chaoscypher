  "examples": {
    "alias_examples": [
      {
        "canonical": "John Michael Smith",
        "aliases": [
          "John Smith",
          "J. Smith",
          "Smith"
        ],
        "note": "Full names shortened to common forms become aliases"
      },
      {
        "canonical": "Federal Bureau of Investigation",
        "aliases": [
          "FBI",
          "the Bureau"
        ],
        "note": "Agency abbreviations and common references become aliases"
      },
      {
        "canonical": "Smith & Wesson M&P Shield 9mm",
        "aliases": [
          "the 9mm",
          "suspect's firearm"
        ],
        "note": "Weapon descriptions and references become aliases"
      }
    ],
    "relationship_examples": [
      {
        "source": "Detective Martinez",
        "target": "123 Oak Street Homicide",
        "type": "investigated",
        "note": "Use investigated for who worked the case"
      },
      {
        "source": "9mm Glock 19",
        "target": "Victim's Residence",
        "type": "found_at",
        "note": "Use found_at for evidence-location connections"
      },
      {
        "source": "John Smith",
        "target": "Murder of Jane Doe",
        "type": "involved_in",
        "note": "Use involved_in for general participation in events"
      },
      {
        "source": "Autopsy Report #2024-0142",
        "target": "Witness Statement of Dr. Lee",
        "type": "corroborates",
        "note": "Use corroborates when evidence supports other evidence"
      }
    ]
  },
  "quality_scoring": {
    "default_entity_score": 18,
    "default_relationship_score": 15
  },

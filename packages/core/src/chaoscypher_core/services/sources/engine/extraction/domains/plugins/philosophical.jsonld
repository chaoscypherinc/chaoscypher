{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:philosophical",
  "name": "philosophical",
  "version": "1.10.0",
  "description": "Philosophical texts from global traditions (Western, Eastern, African, Islamic, Indigenous)",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.15,
  "strict_entity_types": true,
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "philosophical_core": {
        "terms": [
          "philosophy",
          "philosopher",
          "metaphysics",
          "epistemology",
          "ontology",
          "ethics",
          "aesthetics",
          "logic",
          "wisdom",
          "reasoning",
          "dialectic",
          "worldview",
          "philosophical",
          "principle",
          "axiom",
          "universal law",
          "fundamental truth"
        ],
        "weight": 1.2
      },
      "esoteric_philosophy": {
        "terms": [
          "hermetic",
          "hermeticism",
          "hermetical",
          "esoteric",
          "occult",
          "mystical",
          "gnostic",
          "gnosticism",
          "neoplatonic",
          "neoplatonism",
          "alchemy",
          "alchemical",
          "transmutation",
          "initiate",
          "adept",
          "theosophy",
          "rosicrucian",
          "kabbalah",
          "qabbalah",
          "arcane",
          "occultism"
        ],
        "weight": 1.1
      },
      "western_philosophy": {
        "terms": [
          "phenomenology",
          "existentialism",
          "rationalism",
          "empiricism",
          "idealism",
          "materialism",
          "stoicism",
          "skepticism",
          "pragmatism",
          "analytic philosophy",
          "continental philosophy",
          "hermeneutics",
          "deconstruction",
          "postmodernism"
        ],
        "weight": 0.9
      },
      "eastern_philosophy": {
        "terms": [
          "dharma",
          "karma",
          "samsara",
          "nirvana",
          "moksha",
          "tao",
          "yin yang",
          "confucian",
          "buddhist",
          "vedanta",
          "zen",
          "sunyata",
          "ahimsa",
          "wu wei",
          "li",
          "ren",
          "atman",
          "brahman"
        ],
        "weight": 0.9
      },
      "african_philosophy": {
        "terms": [
          "ubuntu",
          "maat",
          "sankofa",
          "ujamaa",
          "negritude",
          "ethnophilosophy",
          "sage philosophy",
          "african communalism",
          "ancestral wisdom"
        ],
        "weight": 0.9
      },
      "islamic_philosophy": {
        "terms": [
          "falsafa",
          "kalam",
          "tawhid",
          "fitra",
          "ijtihad",
          "maqasid",
          "sufism",
          "tasawwuf",
          "hikma"
        ],
        "weight": 0.9
      },
      "argument_structure": {
        "terms": [
          "therefore",
          "hence",
          "thus",
          "premise",
          "conclusion",
          "argument",
          "thesis",
          "antithesis",
          "synthesis",
          "refutation",
          "objection",
          "syllogism",
          "inference",
          "deduction",
          "induction"
        ],
        "weight": 1.0
      },
      "latin_greek_terms": {
        "terms": [
          "a priori",
          "a posteriori",
          "prima facie",
          "sui generis",
          "ad hominem",
          "reductio ad absurdum",
          "qua",
          "per se",
          "in se",
          "cogito",
          "tabula rasa",
          "eudaimonia",
          "logos",
          "telos",
          "phronesis",
          "arete"
        ],
        "weight": 1.3
      },
      "major_concepts": {
        "terms": [
          "consciousness",
          "free will",
          "determinism",
          "substance",
          "essence",
          "existence",
          "being",
          "nothingness",
          "truth",
          "knowledge",
          "belief",
          "justification",
          "causation",
          "modality",
          "necessity",
          "contingency",
          "virtue",
          "justice",
          "beauty",
          "the good"
        ],
        "weight": 0.8
      },
      "major_thinkers": {
        "terms": [
          "Plato",
          "Aristotle",
          "Socrates",
          "Kant",
          "Hegel",
          "Nietzsche",
          "Heidegger",
          "Wittgenstein",
          "Descartes",
          "Locke",
          "Hume",
          "Spinoza",
          "Confucius",
          "Mencius",
          "Laozi",
          "Zhuangzi",
          "Buddha",
          "Nagarjuna",
          "Shankara",
          "Ibn Rushd",
          "Al-Ghazali",
          "Ibn Sina",
          "Sartre",
          "Foucault",
          "Derrida",
          "Hermes Trismegistus",
          "Plotinus",
          "Pythagoras",
          "Parmenides",
          "Heraclitus"
        ],
        "weight": 0.8
      }
    },
    "file_extensions": [],
    "doc_types": [
      "academic_paper",
      "philosophy_text",
      "treatise",
      "dialogue"
    ],
    "patterns": [
      {
        "regex": "(?i)\\b(argues?|contends?|maintains?|holds?|asserts?|claims?)\\s+that\\b",
        "weight": 1.2,
        "description": "Argument introduction patterns"
      },
      {
        "regex": "(?i)\\b(a\\s+priori|a\\s+posteriori|prima\\s+facie|sui\\s+generis|per\\s+se|qua|ipso\\s+facto)\\b",
        "weight": 1.4,
        "description": "Latin philosophical terms"
      },
      {
        "regex": "(?i)\\b[A-Z][a-z]+(?:'s|ian)\\s+(philosophy|theory|view|argument|thesis|critique|ethics|metaphysics|epistemology)\\b",
        "weight": 1.1,
        "description": "Philosopher's theory references"
      },
      {
        "regex": "(?i)\\bthe\\s+principle\\s+of\\s+[A-Z]",
        "weight": 1.5,
        "description": "The Principle of X pattern"
      },
      {
        "regex": "(?i)\\b(universal|cosmic|natural|mental|divine|eternal)\\s+law\\b",
        "weight": 1.3,
        "description": "Universal/cosmic law references"
      },
      {
        "regex": "(?i)\\bhermetic\\s+(philosophy|teaching|principle|wisdom|tradition)\\b",
        "weight": 1.6,
        "description": "Hermetic philosophy references"
      },
      {
        "regex": "(?i)\\b(therefore|hence|thus|consequently|it\\s+follows\\s+that)\\b",
        "weight": 0.8,
        "description": "Logical connectives"
      }
    ],
    "confidence": {
      "base_score": 0.3,
      "per_keyword_boost": 0.04,
      "extension_boost": 0.0,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_exclusions": [
    {
      "description": "Section markers",
      "examples": [
        "Chapter 1",
        "Part II",
        "Section 3"
      ]
    },
    {
      "description": "Footnote references",
      "examples": [
        "[1]",
        "(ibid.)",
        "op. cit."
      ]
    },
    {
      "description": "Generic academic terms",
      "examples": [
        "this paper",
        "the author",
        "as mentioned above"
      ]
    },
    {
      "description": "Vague references",
      "examples": [
        "some philosophers",
        "it is argued that"
      ]
    }
  ],
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- Extract philosophers, concepts, arguments, principles, and schools of thought\n- CROSS-CULTURAL: Look for influences across traditions (Eastern/Western/African/Islamic)\n- PRINCIPLES: Extract universal laws and first principles as separate entities\n\nDO NOT EXTRACT:\n- Section markers: Chapter 1, Part II, Section numbers\n- Footnote references: [1], (ibid.), op. cit.\n- Generic academic terms: 'this paper', 'the author', 'as mentioned above'\n- Vague references: 'some philosophers', 'it is argued that' (without specific attribution)",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- ARGUMENTS: Capture the logical structure - link premises to conclusions with supports/presupposes\n- DEBATES: Use argues_for/argues_against to show philosophical disagreements\n- INFLUENCE: Use influenced_by to show intellectual lineage\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",

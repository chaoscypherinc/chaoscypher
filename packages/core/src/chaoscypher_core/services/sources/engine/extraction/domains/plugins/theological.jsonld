{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:theological",
  "name": "theological",
  "version": "1.10.0",
  "description": "Religious texts, theology, sacred writings, and spiritual traditions",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.15,
  "strict_entity_types": true,
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "religious_core": {
        "terms": [
          "god",
          "divine",
          "sacred",
          "holy",
          "spiritual",
          "religion",
          "faith",
          "worship",
          "prayer",
          "salvation",
          "soul",
          "spirit",
          "blessing"
        ],
        "weight": 1.1
      },
      "traditions": {
        "terms": [
          "christianity",
          "islam",
          "judaism",
          "hinduism",
          "buddhism",
          "sikhism",
          "taoism",
          "shinto",
          "zoroastrianism",
          "jainism",
          "confucianism"
        ],
        "weight": 1.0
      },
      "texts": {
        "terms": [
          "scripture",
          "bible",
          "quran",
          "torah",
          "vedas",
          "sutra",
          "gospel",
          "revelation",
          "prophecy",
          "psalm",
          "hadith",
          "upanishad",
          "tanakh"
        ],
        "weight": 1.2
      },
      "concepts": {
        "terms": [
          "sin",
          "redemption",
          "karma",
          "afterlife",
          "heaven",
          "hell",
          "paradise",
          "covenant",
          "dharma",
          "nirvana",
          "moksha",
          "grace",
          "resurrection"
        ],
        "weight": 0.9
      },
      "figures": {
        "terms": [
          "prophet",
          "messiah",
          "saint",
          "angel",
          "deity",
          "avatar",
          "guru",
          "priest",
          "rabbi",
          "imam",
          "apostle",
          "patriarch",
          "monk"
        ],
        "weight": 0.9
      },
      "practices": {
        "terms": [
          "ritual",
          "ceremony",
          "sacrament",
          "pilgrimage",
          "fasting",
          "meditation",
          "prayer",
          "baptism",
          "communion",
          "sacrifice"
        ],
        "weight": 0.8
      }
    },
    "file_extensions": [],
    "doc_types": [
      "religious_text",
      "theological_document",
      "scripture"
    ],
    "patterns": [
      {
        "regex": "(?i)\\b(chapter|verse|surah|psalm|book)\\s+\\d+[:\\.]?\\d*\\b",
        "weight": 1.4,
        "description": "Scripture references"
      },
      {
        "regex": "(?i)\\b(the lord|god said|thus saith|it is written|and the lord|saith the lord)\\b",
        "weight": 1.2,
        "description": "Divine speech patterns"
      },
      {
        "regex": "(?i)\\b(blessed|holy|sacred|divine|righteous)\\s+(be|is|are|art)\\b",
        "weight": 1.1,
        "description": "Religious language"
      },
      {
        "regex": "(?i)\\b\\d+:\\d+(-\\d+)?\\b",
        "weight": 0.8,
        "description": "Chapter:verse notation"
      }
    ],
    "confidence": {
      "base_score": 0.25,
      "per_keyword_boost": 0.04,
      "extension_boost": 0.0,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_exclusions": [
    {
      "description": "Chapter:verse references",
      "examples": [
        "John 3:16",
        "Quran 2:255",
        "Psalm 23:1"
      ]
    },
    {
      "description": "Generic devotional language",
      "examples": [
        "the Lord",
        "God said"
      ]
    },
    {
      "description": "Liturgical responses",
      "examples": [
        "Amen",
        "Hallelujah",
        "Peace be upon him"
      ]
    }
  ],
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- Extract deities, prophets, sacred texts, doctrines, traditions, and practices\n- Include religious traditions and denominations\n- Use canonical names with common variants as aliases\n\nDO NOT EXTRACT:\n- Chapter:verse references: John 3:16, Quran 2:255, Psalm 23:1\n- Generic devotional language: 'the Lord', 'God said' (without specific context)\n- Liturgical responses: 'Amen', 'Hallelujah', 'Peace be upon him'\n- Modern editorial additions: verse numbers, section headers, translator notes",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- FIGURES: Link prophets/figures to traditions with founded, belongs_to\n- TEXTS: Connect texts to doctrines with teaches\n- PRACTICES: Link traditions to practices with practices\n- REVELATION: Use revealed for divine communications\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",

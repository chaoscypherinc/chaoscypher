        "canonical": "Napoleon Bonaparte",
        "aliases": [
          "Napoleon I",
          "Emperor Napoleon",
          "The Little Corporal"
        ],
        "note": "Titles and epithets become aliases"
      }
    ],
    "relationship_examples": [
      {
        "source": "Napoleon",
        "target": "Battle of Waterloo",
        "type": "participated_in",
        "note": "Use participated_in for figure-event connections"
      },
      {

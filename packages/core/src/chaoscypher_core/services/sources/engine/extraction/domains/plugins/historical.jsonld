{
  "@context": {
    "@vocab": "https://chaoscypher.io/schema/domain#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description",
    "author": "schema:author",
    "version": "schema:version"
  },
  "@type": "ExtractionDomain",
  "@id": "domain:historical",
  "name": "historical",
  "version": "1.11.0",
  "description": "Historical documents, narratives, primary sources, and historiography",
  "author": "ChaosCypher Team",
  "builtin": true,
  "extraction_density": 1.1,
  "strict_entity_types": true,
  "detection": {
    "@type": "DetectionConfig",
    "keywords": {
      "temporal": {
        "terms": [
          "century",
          "era",
          "period",
          "epoch",
          "decade",
          "millennium",
          "antiquity"
        ],
        "weight": 1.0
      },
      "events": {
        "terms": [
          "war",
          "treaty",
          "revolution",
          "battle",
          "reign",
          "conquest",
          "rebellion",
          "uprising",
          "independence",
          "colonization"
        ],
        "weight": 1.1
      },
      "structures": {
        "terms": [
          "dynasty",
          "empire",
          "kingdom",
          "republic",
          "monarchy",
          "civilization",
          "colony",
          "federation"
        ],
        "weight": 0.9
      },
      "historical_terms": {
        "terms": [
          "historical",
          "history",
          "medieval",
          "pre-historic",
          "classical",
          "renaissance",
          "enlightenment",
          "historiography",
          "historian"
        ],
        "weight": 1.0
      },
      "sources": {
        "terms": [
          "primary source",
          "chronicle",
          "manuscript",
          "archive",
          "artifact",
          "archaeological",
          "inscription",
          "document",
          "record"
        ],
        "weight": 0.9
      },
      "actors": {
        "terms": [
          "king",
          "queen",
          "emperor",
          "pharaoh",
          "sultan",
          "tsar",
          "general",
          "statesman",
          "reformer",
          "leader"
        ],
        "weight": 0.8
      }
    },
    "file_extensions": [],
    "doc_types": [
      "historical_document",
      "primary_source",
      "historiography"
    ],
    "patterns": [
      {
        "regex": "(?i)\\b\\d{1,2}(st|nd|rd|th)\\s+century\\b",
        "weight": 1.4,
        "description": "Century references"
      },
      {
        "regex": "(?i)\\b\\d{3,4}\\s*(ad|bc|bce|ce|a\\.d\\.|b\\.c\\.)\\b",
        "weight": 1.3,
        "description": "Year with era"
      },
      {
        "regex": "(?i)\\b(circa|c\\.|ca\\.|approx\\.?)\\s*\\d{3,4}\\b",
        "weight": 1.2,
        "description": "Approximate dates"
      },
      {
        "regex": "(?i)\\b(reign|ruled|dynasty|era|period|age)\\s+of\\b",
        "weight": 1.1,
        "description": "Reign/period patterns"
      },
      {
        "regex": "(?i)\\b(ancient|medieval|renaissance|modern|pre-war|post-war|colonial)\\b",
        "weight": 0.9,
        "description": "Historical era terms"
      }
    ],
    "confidence": {
      "base_score": 0.25,
      "per_keyword_boost": 0.04,
      "extension_boost": 0.0,
      "doc_type_boost": 0.25,
      "pattern_boost": 0.15,
      "max_confidence": 0.95,
      "min_threshold": 0.4
    }
  },
  "entity_exclusions": [
    {
      "description": "Vague date references",
      "examples": [
        "at that time",
        "in those days",
        "later"
      ]
    },
    {
      "description": "Generic terms without specific identity",
      "examples": [
        "the king",
        "the army",
        "the people"
      ]
    }
  ],
  "entity_guidance": "ENTITY EXTRACTION RULES:\n- Extract historical events, figures, eras, locations, and primary sources\n- Use canonical names with all variants as aliases\n- Include dates and time periods in properties\n\nDO NOT EXTRACT:\n- Vague date references: 'at that time', 'in those days', 'later'\n- Generic terms: 'the king', 'the army', 'the people' (without specific identity)\n- Modern editorial content: footnote numbers, [sic], translator notes\n- Page or chapter references from the source document",
  "relationship_guidance": "RELATIONSHIP EXTRACTION RULES:\n- CHRONOLOGY: Link events to eras with occurred_during. Use preceded for sequences\n- CAUSATION: Capture cause-effect chains with caused relationship\n- FIGURES: Use participated_in, led, signed for historical figures' roles\n- SOURCES: Link events to primary sources with documented_in\n\nUNIVERSAL RULES (apply to every relationship):\n- DIRECTIONALITY: each predicate has a listed source→target direction. Don't reverse it, even when the relation could be read either way.\n- NO HALLUCINATED PREDICATES: only emit relationship types listed in the templates above. Do NOT invent new ones — pick the closest listed predicate instead.\n- SPECIFICITY: prefer specific named predicates over generic ones like 'related_to', 'associated_with', or 'interacts_with'.",
  "templates": {
    "node_templates": [
      {
        "@type": "NodeTemplate",
        "id": "hist_template_event",
        "name": "Historical Event",
        "description": "A significant historical occurrence or event",
        "icon": "Event",
        "color": "#d68341",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "events",
        "normalization_keywords": [
          "event",
          "occurred in",
          "took place",
          "battle of",
          "treaty of",
          "war of",
          "revolution",
          "siege of"
        ]
      },
      {
        "@type": "NodeTemplate",
        "id": "hist_template_figure",
        "name": "Historical Figure",
        "description": "A person of historical significance",
        "icon": "Person",
        "color": "#d6b841",
        "requires_named_referent": true,
        "quality_score": 25,
        "compatibility_group": "people",
        "normalization_keywords": [
          "historical figure",
          "king",
          "emperor",
          "ruler",
          "leader",
          "statesman",
          "general",
          "reformer"
        ],
        "properties": [
          {
            "name": "birth_year",
            "display_name": "Birth Year",
            "property_type": "text",
            "absorbs_types": [
              "Birth Year"
            ]
          },
          {
            "name": "death_year",
            "display_name": "Death Year",
            "property_type": "text",
            "absorbs_types": [
              "Death Year"
            ]
          },
          {
            "name": "title",
            "display_name": "Title",
            "property_type": "text",
            "absorbs_types": [
              "Title"
            ]
          },
          {
            "name": "nationality",

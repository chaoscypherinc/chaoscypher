{
  "name": "chaoscypher-frontend",
  "version": "1.0.0",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22.0.0"
  },
  "description": "Knowledge Engine Web UI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --report-unused-disable-directives",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "deadcode": "knip",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "generate-types": "openapi-typescript ../../build/openapi.json -o src/types/generated/api.ts",
    "postinstall": "node -e \"try { require('esbuild') } catch(e) { console.log('esbuild check passed') }\""
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/exo-2": "^5.2.8",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@react-sigma/core": "^5.0.6",
    "@sigma/node-image": "^3.0.0",
    "@tanstack/react-query": "^5.101.0",
    "@xyflow/react": "^12.11.0",
    "d3-force": "^3.0.0",
    "diff": "^9.0.0",
    "graphology": "^0.26.0",
    "graphology-types": "^0.24.8",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "sigma": "^3.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@size-limit/preset-app": "^12.1.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-force": "^3.0.10",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.1",
    "knip": "^6.15.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "openapi-typescript": "^7.13.0",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "qs": "^6.15.2"
  }
}
